>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. COACTVWC.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT ACCOUNT-FILE ASSIGN TO DYNAMIC WS-ACCOUNT-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-ACCOUNT-STATUS.
    SELECT CUSTOMER-FILE ASSIGN TO DYNAMIC WS-CUSTOMER-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-CUSTOMER-STATUS.
    SELECT XREF-FILE ASSIGN TO DYNAMIC WS-XREF-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-XREF-STATUS.

DATA DIVISION.
FILE SECTION.
FD ACCOUNT-FILE.
01 ACCOUNT-RAW-RECORD PIC X(300).

FD CUSTOMER-FILE.
01 CUSTOMER-RAW-RECORD PIC X(500).

FD XREF-FILE.
01 XREF-RAW-RECORD PIC X(50).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-ACCOUNT-PATH              PIC X(256) VALUE SPACES.
   05 WS-CUSTOMER-PATH             PIC X(256) VALUE SPACES.
   05 WS-XREF-PATH                 PIC X(256) VALUE SPACES.
   05 WS-ACCOUNT-STATUS            PIC X(02) VALUE SPACES.
   05 WS-CUSTOMER-STATUS           PIC X(02) VALUE SPACES.
   05 WS-XREF-STATUS               PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-ACCOUNT-FOUND             PIC X VALUE "N".
      88 ACCOUNT-FOUND                         VALUE "Y".
      88 ACCOUNT-NOT-FOUND                     VALUE "N".
   05 WS-CUSTOMER-FOUND            PIC X VALUE "N".
      88 CUSTOMER-FOUND                        VALUE "Y".
      88 CUSTOMER-NOT-FOUND                    VALUE "N".
   05 WS-XREF-FOUND                PIC X VALUE "N".
      88 XREF-FOUND                            VALUE "Y".
      88 XREF-NOT-FOUND                        VALUE "N".
   05 WS-END-OF-FILE               PIC X VALUE "N".
      88 END-OF-FILE                           VALUE "Y".
      88 MORE-RECORDS                          VALUE "N".

01 WS-INPUT.
   05 WS-SEARCH-ACCOUNT-ID         PIC X(11) VALUE SPACES.
   05 WS-SEARCH-CARD-NUM           PIC X(16) VALUE SPACES.
   05 WS-MENU-RESPONSE             PIC X VALUE SPACE.

01 WS-XREF-DATA.
   05 WS-XREF-CARD-NUM             PIC X(16).
   05 WS-XREF-CUST-ID              PIC X(09).
   05 WS-XREF-ACCT-ID              PIC X(11).

01 WS-ACCOUNT-DATA.
   05 WS-ACCT-ID                   PIC X(11).
   05 WS-ACCT-STATUS               PIC X(01).
   05 WS-ACCT-CURR-BAL             PIC X(12).
   05 WS-ACCT-CREDIT-LIMIT         PIC X(12).
   05 WS-ACCT-CASH-LIMIT           PIC X(12).
   05 WS-ACCT-OPEN-DATE            PIC X(10).
   05 WS-ACCT-EXP-DATE             PIC X(10).
   05 WS-ACCT-REISSUE-DATE         PIC X(10).
   05 WS-ACCT-CURR-CYC-CREDIT      PIC X(12).
   05 WS-ACCT-CURR-CYC-DEBIT       PIC X(12).
   05 WS-ACCT-ZIP                  PIC X(10).
   05 WS-ACCT-GROUP-ID             PIC X(10).

01 WS-CUSTOMER-DATA.
   05 WS-CUST-ID                   PIC X(09).
   05 WS-CUST-FIRST-NAME           PIC X(25).
   05 WS-CUST-MIDDLE-NAME          PIC X(25).
   05 WS-CUST-LAST-NAME            PIC X(25).
   05 WS-CUST-ADDR-LINE-1          PIC X(50).
   05 WS-CUST-ADDR-LINE-2          PIC X(50).
   05 WS-CUST-ADDR-LINE-3          PIC X(50).
   05 WS-CUST-STATE                PIC X(02).
   05 WS-CUST-COUNTRY              PIC X(03).
   05 WS-CUST-ZIP                  PIC X(10).
   05 WS-CUST-PHONE-1              PIC X(15).
   05 WS-CUST-PHONE-2              PIC X(15).

01 WS-AMOUNTS.
   05 WS-CURRENT-AMOUNT            PIC X(12).
   05 WS-AMOUNT-WORK               PIC X(12).
   05 WS-AMOUNT-DIGITS             PIC X(12).
   05 WS-AMOUNT-SIGN               PIC X VALUE "+".
   05 WS-AMOUNT-LAST-CHAR          PIC X.
   05 WS-AMOUNT-LAST-DIGIT         PIC X.
   05 WS-FORMATTED-AMOUNT          PIC X(16).

01 WS-TEXT.
   05 WS-DISPLAY-NAME              PIC X(80).

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATHS
    DISPLAY SPACE
    DISPLAY "Account View"
    DISPLAY "Lookup by account ID or card number."
    DISPLAY "Account ID (11 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-ACCOUNT-ID
    DISPLAY "Card Number (16 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-CARD-NUM

    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
        AND FUNCTION TRIM(WS-SEARCH-CARD-NUM) = SPACES
        DISPLAY "You must enter an account ID or a card number."
        GOBACK
    END-IF

    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
        PERFORM FIND-XREF-BY-CARD
        IF XREF-NOT-FOUND
            DISPLAY "No card/account cross reference found."
            GOBACK
        END-IF
        MOVE WS-XREF-ACCT-ID TO WS-SEARCH-ACCOUNT-ID
    ELSE
        PERFORM FIND-XREF-BY-ACCOUNT
    END-IF

    PERFORM FIND-ACCOUNT
    IF ACCOUNT-NOT-FOUND
        DISPLAY "Account not found."
        GOBACK
    END-IF

    IF XREF-NOT-FOUND
        PERFORM FIND-XREF-BY-ACCOUNT
    END-IF
    IF XREF-FOUND
        PERFORM FIND-CUSTOMER
    END-IF

    PERFORM DISPLAY-ACCOUNT
    GOBACK.

INITIALIZE-PATHS.
    ACCEPT WS-ACCOUNT-PATH FROM ENVIRONMENT "CARDDEMO_ACCT_PATH"
    IF WS-ACCOUNT-PATH = SPACES
        MOVE "app/data/ASCII/acctdata.txt" TO WS-ACCOUNT-PATH
    END-IF
    ACCEPT WS-CUSTOMER-PATH FROM ENVIRONMENT "CARDDEMO_CUST_PATH"
    IF WS-CUSTOMER-PATH = SPACES
        MOVE "app/data/ASCII/custdata.txt" TO WS-CUSTOMER-PATH
    END-IF
    ACCEPT WS-XREF-PATH FROM ENVIRONMENT "CARDDEMO_XREF_PATH"
    IF WS-XREF-PATH = SPACES
        MOVE "app/data/ASCII/cardxref.txt" TO WS-XREF-PATH
    END-IF.

FIND-XREF-BY-CARD.
    SET XREF-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(1:16) = WS-SEARCH-CARD-NUM
                    MOVE XREF-RAW-RECORD(1:16) TO WS-XREF-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-XREF-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-XREF-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

FIND-XREF-BY-ACCOUNT.
    SET XREF-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(26:11) = WS-SEARCH-ACCOUNT-ID
                    MOVE XREF-RAW-RECORD(1:16) TO WS-XREF-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-XREF-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-XREF-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

FIND-ACCOUNT.
    SET ACCOUNT-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT ACCOUNT-FILE
    IF WS-ACCOUNT-STATUS NOT = "00"
        DISPLAY "Unable to open account file. Status: " WS-ACCOUNT-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE OR ACCOUNT-FOUND
        READ ACCOUNT-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF ACCOUNT-RAW-RECORD(1:11) = WS-SEARCH-ACCOUNT-ID
                    MOVE ACCOUNT-RAW-RECORD(1:11) TO WS-ACCT-ID
                    MOVE ACCOUNT-RAW-RECORD(12:1) TO WS-ACCT-STATUS
                    MOVE ACCOUNT-RAW-RECORD(13:12) TO WS-ACCT-CURR-BAL
                    MOVE ACCOUNT-RAW-RECORD(25:12) TO WS-ACCT-CREDIT-LIMIT
                    MOVE ACCOUNT-RAW-RECORD(37:12) TO WS-ACCT-CASH-LIMIT
                    MOVE ACCOUNT-RAW-RECORD(49:10) TO WS-ACCT-OPEN-DATE
                    MOVE ACCOUNT-RAW-RECORD(59:10) TO WS-ACCT-EXP-DATE
                    MOVE ACCOUNT-RAW-RECORD(69:10) TO WS-ACCT-REISSUE-DATE
                    MOVE ACCOUNT-RAW-RECORD(79:12) TO WS-ACCT-CURR-CYC-CREDIT
                    MOVE ACCOUNT-RAW-RECORD(91:12) TO WS-ACCT-CURR-CYC-DEBIT
                    MOVE ACCOUNT-RAW-RECORD(103:10) TO WS-ACCT-ZIP
                    MOVE ACCOUNT-RAW-RECORD(113:10) TO WS-ACCT-GROUP-ID
                    SET ACCOUNT-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE ACCOUNT-FILE.

FIND-CUSTOMER.
    SET CUSTOMER-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT CUSTOMER-FILE
    IF WS-CUSTOMER-STATUS NOT = "00"
        DISPLAY "Unable to open customer file. Status: " WS-CUSTOMER-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE OR CUSTOMER-FOUND
        READ CUSTOMER-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF CUSTOMER-RAW-RECORD(1:9) = WS-XREF-CUST-ID
                    MOVE CUSTOMER-RAW-RECORD(1:9) TO WS-CUST-ID
                    MOVE CUSTOMER-RAW-RECORD(10:25) TO WS-CUST-FIRST-NAME
                    MOVE CUSTOMER-RAW-RECORD(35:25) TO WS-CUST-MIDDLE-NAME
                    MOVE CUSTOMER-RAW-RECORD(60:25) TO WS-CUST-LAST-NAME
                    MOVE CUSTOMER-RAW-RECORD(85:50) TO WS-CUST-ADDR-LINE-1
                    MOVE CUSTOMER-RAW-RECORD(135:50) TO WS-CUST-ADDR-LINE-2
                    MOVE CUSTOMER-RAW-RECORD(185:50) TO WS-CUST-ADDR-LINE-3
                    MOVE CUSTOMER-RAW-RECORD(235:2) TO WS-CUST-STATE
                    MOVE CUSTOMER-RAW-RECORD(237:3) TO WS-CUST-COUNTRY
                    MOVE CUSTOMER-RAW-RECORD(240:10) TO WS-CUST-ZIP
                    MOVE CUSTOMER-RAW-RECORD(250:15) TO WS-CUST-PHONE-1
                    MOVE CUSTOMER-RAW-RECORD(265:15) TO WS-CUST-PHONE-2
                    SET CUSTOMER-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE CUSTOMER-FILE.

DISPLAY-ACCOUNT.
    DISPLAY SPACE
    DISPLAY "Account Detail"
    DISPLAY "Account ID      : " WS-ACCT-ID
    DISPLAY "Status          : " WS-ACCT-STATUS
    MOVE WS-ACCT-CURR-BAL TO WS-CURRENT-AMOUNT
    PERFORM FORMAT-AMOUNT
    DISPLAY "Current Balance : " WS-FORMATTED-AMOUNT
    MOVE WS-ACCT-CREDIT-LIMIT TO WS-CURRENT-AMOUNT
    PERFORM FORMAT-AMOUNT
    DISPLAY "Credit Limit    : " WS-FORMATTED-AMOUNT
    MOVE WS-ACCT-CASH-LIMIT TO WS-CURRENT-AMOUNT
    PERFORM FORMAT-AMOUNT
    DISPLAY "Cash Limit      : " WS-FORMATTED-AMOUNT
    DISPLAY "Open Date       : " WS-ACCT-OPEN-DATE
    DISPLAY "Expiry Date     : " WS-ACCT-EXP-DATE
    DISPLAY "Reissue Date    : " WS-ACCT-REISSUE-DATE
    DISPLAY "ZIP             : " WS-ACCT-ZIP
    DISPLAY "Group ID        : " WS-ACCT-GROUP-ID
    IF XREF-FOUND
        DISPLAY "Card Number     : " WS-XREF-CARD-NUM
        DISPLAY "Customer ID     : " WS-XREF-CUST-ID
    END-IF
    IF CUSTOMER-FOUND
        STRING FUNCTION TRIM(WS-CUST-FIRST-NAME) SPACE
            FUNCTION TRIM(WS-CUST-MIDDLE-NAME) SPACE
            FUNCTION TRIM(WS-CUST-LAST-NAME)
            DELIMITED BY SIZE
            INTO WS-DISPLAY-NAME
        END-STRING
        DISPLAY "Customer Name   : " FUNCTION TRIM(WS-DISPLAY-NAME)
        DISPLAY "Address 1       : " FUNCTION TRIM(WS-CUST-ADDR-LINE-1)
        IF FUNCTION TRIM(WS-CUST-ADDR-LINE-2) NOT = SPACES
            DISPLAY "Address 2       : " FUNCTION TRIM(WS-CUST-ADDR-LINE-2)
        END-IF
        IF FUNCTION TRIM(WS-CUST-ADDR-LINE-3) NOT = SPACES
            DISPLAY "Address 3       : " FUNCTION TRIM(WS-CUST-ADDR-LINE-3)
        END-IF
        DISPLAY "State/Country   : " WS-CUST-STATE " / " WS-CUST-COUNTRY
        DISPLAY "Customer ZIP    : " WS-CUST-ZIP
        DISPLAY "Phone 1         : " FUNCTION TRIM(WS-CUST-PHONE-1)
        DISPLAY "Phone 2         : " FUNCTION TRIM(WS-CUST-PHONE-2)
    ELSE
        DISPLAY "Customer detail : not found"
    END-IF.

FORMAT-AMOUNT.
    MOVE WS-CURRENT-AMOUNT TO WS-AMOUNT-DIGITS
    MOVE "+" TO WS-AMOUNT-SIGN
    MOVE WS-AMOUNT-DIGITS(12:1) TO WS-AMOUNT-LAST-CHAR
    EVALUATE WS-AMOUNT-LAST-CHAR
        WHEN "{"
            MOVE "0" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "A"
            MOVE "1" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "B"
            MOVE "2" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "C"
            MOVE "3" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "D"
            MOVE "4" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "E"
            MOVE "5" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "F"
            MOVE "6" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "G"
            MOVE "7" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "H"
            MOVE "8" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "I"
            MOVE "9" TO WS-AMOUNT-LAST-DIGIT
            MOVE "+" TO WS-AMOUNT-SIGN
        WHEN "}"
            MOVE "0" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN "J"
            MOVE "1" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN "K"
            MOVE "2" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN "L"
            MOVE "3" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN "M"
            MOVE "4" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN "N"
            MOVE "5" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN "O"
            MOVE "6" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN "P"
            MOVE "7" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN "Q"
            MOVE "8" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN "R"
            MOVE "9" TO WS-AMOUNT-LAST-DIGIT
            MOVE "-" TO WS-AMOUNT-SIGN
        WHEN OTHER
            MOVE WS-AMOUNT-LAST-CHAR TO WS-AMOUNT-LAST-DIGIT
    END-EVALUATE
    MOVE WS-AMOUNT-LAST-DIGIT TO WS-AMOUNT-DIGITS(12:1)
    STRING WS-AMOUNT-SIGN
        FUNCTION TRIM(WS-AMOUNT-DIGITS(1:10))
        "."
        WS-AMOUNT-DIGITS(11:2)
        DELIMITED BY SIZE
        INTO WS-FORMATTED-AMOUNT
    END-STRING.
