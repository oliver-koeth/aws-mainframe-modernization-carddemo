>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. COCRDLIC.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT CARD-FILE ASSIGN TO DYNAMIC WS-CARD-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-CARD-STATUS.

DATA DIVISION.
FILE SECTION.
FD CARD-FILE.
01 CARD-RAW-RECORD PIC X(150).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-CARD-PATH                 PIC X(256) VALUE SPACES.
   05 WS-CARD-STATUS               PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-END-OF-FILE               PIC X VALUE "N".
      88 END-OF-FILE                           VALUE "Y".
      88 MORE-RECORDS                          VALUE "N".
   05 WS-DONE                      PIC X VALUE "N".
      88 LIST-DONE                             VALUE "Y".
      88 LIST-ACTIVE                           VALUE "N".

01 WS-FILTERS.
   05 WS-FILTER-ACCOUNT-ID         PIC X(11) VALUE SPACES.
   05 WS-FILTER-CARD-NUM           PIC X(16) VALUE SPACES.
   05 WS-NAV-CHOICE                PIC X(10) VALUE SPACES.

01 WS-COUNTERS.
   05 WS-CARD-COUNT                PIC 9(04) VALUE 0.
   05 WS-FILTERED-COUNT            PIC 9(04) VALUE 0.
   05 WS-PAGE-SIZE                 PIC 9(02) VALUE 7.
   05 WS-PAGE-START                PIC 9(04) VALUE 1.
   05 WS-PAGE-END                  PIC 9(04) VALUE 0.
   05 WS-IDX                       PIC 9(04) VALUE 0.

01 WS-CARDS.
   05 WS-CARD-ENTRY OCCURS 500 TIMES.
      10 WS-CARD-LINE              PIC X(150).

01 WS-FILTERED-INDICES.
   05 WS-FILTERED-INDEX OCCURS 500 TIMES PIC 9(04).

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATH
    PERFORM LOAD-CARDS
    PERFORM PROMPT-FILTERS
    PERFORM BUILD-FILTERED-LIST
    IF WS-FILTERED-COUNT = 0
        DISPLAY "No cards found for the supplied filters."
        GOBACK
    END-IF

    SET LIST-ACTIVE TO TRUE
    PERFORM UNTIL LIST-DONE
        PERFORM DISPLAY-PAGE
        DISPLAY "Enter N(ext), P(revious), or Q(uit): " WITH NO ADVANCING
        ACCEPT WS-NAV-CHOICE
        MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-NAV-CHOICE)) TO WS-NAV-CHOICE
        EVALUATE WS-NAV-CHOICE(1:1)
            WHEN "N"
                IF WS-PAGE-END < WS-FILTERED-COUNT
                    ADD WS-PAGE-SIZE TO WS-PAGE-START
                END-IF
            WHEN "P"
                IF WS-PAGE-START > WS-PAGE-SIZE
                    SUBTRACT WS-PAGE-SIZE FROM WS-PAGE-START
                ELSE
                    MOVE 1 TO WS-PAGE-START
                END-IF
            WHEN "Q"
                SET LIST-DONE TO TRUE
            WHEN OTHER
                CONTINUE
        END-EVALUATE
    END-PERFORM
    GOBACK.

INITIALIZE-PATH.
    ACCEPT WS-CARD-PATH FROM ENVIRONMENT "CARDDEMO_CARD_PATH"
    IF WS-CARD-PATH = SPACES
        MOVE "app/data/ASCII/carddata.txt" TO WS-CARD-PATH
    END-IF.

LOAD-CARDS.
    MOVE 0 TO WS-CARD-COUNT
    SET MORE-RECORDS TO TRUE
    OPEN INPUT CARD-FILE
    IF WS-CARD-STATUS NOT = "00"
        DISPLAY "Unable to open card file. Status: " WS-CARD-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ CARD-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                ADD 1 TO WS-CARD-COUNT
                MOVE CARD-RAW-RECORD TO WS-CARD-LINE(WS-CARD-COUNT)
        END-READ
    END-PERFORM
    CLOSE CARD-FILE.

PROMPT-FILTERS.
    DISPLAY SPACE
    DISPLAY "Credit Card List"
    DISPLAY "Account ID filter (optional): " WITH NO ADVANCING
    ACCEPT WS-FILTER-ACCOUNT-ID
    DISPLAY "Card Number filter (optional): " WITH NO ADVANCING
    ACCEPT WS-FILTER-CARD-NUM.

BUILD-FILTERED-LIST.
    MOVE 0 TO WS-FILTERED-COUNT
    MOVE 1 TO WS-PAGE-START
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-CARD-COUNT
        IF (FUNCTION TRIM(WS-FILTER-ACCOUNT-ID) = SPACES
            OR WS-CARD-LINE(WS-IDX)(17:11) = WS-FILTER-ACCOUNT-ID)
           AND
           (FUNCTION TRIM(WS-FILTER-CARD-NUM) = SPACES
            OR WS-CARD-LINE(WS-IDX)(1:16) = WS-FILTER-CARD-NUM)
            ADD 1 TO WS-FILTERED-COUNT
            MOVE WS-IDX TO WS-FILTERED-INDEX(WS-FILTERED-COUNT)
        END-IF
    END-PERFORM.

DISPLAY-PAGE.
    DISPLAY SPACE
    DISPLAY "Credit Card List"
    DISPLAY "Card Number        Account ID   Status  Expiry      Embossed Name"
    DISPLAY "----------------  -----------  ------  ----------  ------------------------------"
    COMPUTE WS-PAGE-END = WS-PAGE-START + WS-PAGE-SIZE - 1
    IF WS-PAGE-END > WS-FILTERED-COUNT
        MOVE WS-FILTERED-COUNT TO WS-PAGE-END
    END-IF
    PERFORM VARYING WS-IDX FROM WS-PAGE-START BY 1 UNTIL WS-IDX > WS-PAGE-END
        DISPLAY WS-CARD-LINE(WS-FILTERED-INDEX(WS-IDX))(1:16) "  "
            WS-CARD-LINE(WS-FILTERED-INDEX(WS-IDX))(17:11) "  "
            WS-CARD-LINE(WS-FILTERED-INDEX(WS-IDX))(91:1) "       "
            WS-CARD-LINE(WS-FILTERED-INDEX(WS-IDX))(81:10) "  "
            FUNCTION TRIM(WS-CARD-LINE(WS-FILTERED-INDEX(WS-IDX))(31:30))
    END-PERFORM
    DISPLAY "Showing " WS-PAGE-START " to " WS-PAGE-END
        " of " WS-FILTERED-COUNT.
