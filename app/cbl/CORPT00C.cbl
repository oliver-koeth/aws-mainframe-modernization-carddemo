>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. CORPT00C.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT REQUEST-FILE ASSIGN TO DYNAMIC WS-REQUEST-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-REQUEST-STATUS.
    SELECT DATEPARM-FILE ASSIGN TO DYNAMIC WS-DATEPARM-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-DATEPARM-STATUS.

DATA DIVISION.
FILE SECTION.
FD REQUEST-FILE.
01 REQUEST-RECORD                    PIC X(200).

FD DATEPARM-FILE.
01 DATEPARM-RECORD                   PIC X(80).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-REQUEST-PATH                PIC X(256) VALUE SPACES.
   05 WS-DATEPARM-PATH               PIC X(256) VALUE SPACES.
   05 WS-REQUEST-STATUS              PIC X(02) VALUE SPACES.
   05 WS-DATEPARM-STATUS             PIC X(02) VALUE SPACES.

01 WS-INPUTS.
   05 WS-REPORT-CHOICE               PIC X(10) VALUE SPACES.
   05 WS-CONFIRM                     PIC X(10) VALUE SPACES.
   05 WS-START-YEAR                  PIC X(04) VALUE SPACES.
   05 WS-START-MONTH                 PIC X(02) VALUE SPACES.
   05 WS-START-DAY                   PIC X(02) VALUE SPACES.
   05 WS-END-YEAR                    PIC X(04) VALUE SPACES.
   05 WS-END-MONTH                   PIC X(02) VALUE SPACES.
   05 WS-END-DAY                     PIC X(02) VALUE SPACES.

01 WS-DATES.
   05 WS-START-DATE.
      10 WS-START-DATE-YYYY          PIC X(04) VALUE SPACES.
      10 FILLER                      PIC X(01) VALUE "-".
      10 WS-START-DATE-MM            PIC X(02) VALUE SPACES.
      10 FILLER                      PIC X(01) VALUE "-".
      10 WS-START-DATE-DD            PIC X(02) VALUE SPACES.
   05 WS-END-DATE.
      10 WS-END-DATE-YYYY            PIC X(04) VALUE SPACES.
      10 FILLER                      PIC X(01) VALUE "-".
      10 WS-END-DATE-MM              PIC X(02) VALUE SPACES.
      10 FILLER                      PIC X(01) VALUE "-".
      10 WS-END-DATE-DD              PIC X(02) VALUE SPACES.
   05 WS-CURRENT-DATE-RAW            PIC X(21) VALUE SPACES.
   05 WS-CURRENT-YEAR                PIC X(04) VALUE SPACES.
   05 WS-CURRENT-MONTH               PIC 9(02) VALUE 0.
   05 WS-CURRENT-DAY                 PIC 9(02) VALUE 0.
   05 WS-NEXT-MONTH                  PIC 9(02) VALUE 0.
   05 WS-NEXT-YEAR                   PIC 9(04) VALUE 0.
   05 WS-END-DATE-N                  PIC 9(08) VALUE 0.
   05 WS-END-DATE-SPLIT REDEFINES WS-END-DATE-N.
      10 WS-END-YEAR-N               PIC 9(04).
      10 WS-END-MONTH-N              PIC 9(02).
      10 WS-END-DAY-N                PIC 9(02).
   05 WS-DATE-CHECK                  PIC X(10) VALUE SPACES.
   05 WS-YEAR-N                      PIC 9(04) VALUE 0.
   05 WS-MONTH-N                     PIC 9(02) VALUE 0.
   05 WS-DAY-N                       PIC 9(02) VALUE 0.

01 WS-WORK.
   05 WS-REPORT-NAME                 PIC X(10) VALUE SPACES.
   05 WS-MESSAGE                     PIC X(120) VALUE SPACES.
   05 WS-TIMESTAMP-DATE              PIC X(10) VALUE SPACES.
   05 WS-TIMESTAMP-TIME              PIC X(08) VALUE SPACES.
   05 WS-TIMESTAMP                   PIC X(19) VALUE SPACES.
   05 WS-REQUEST-LINE                PIC X(200) VALUE SPACES.
   05 WS-DATEPARM-LINE               PIC X(80) VALUE SPACES.

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATHS
    PERFORM PROMPT-FOR-REPORT
    PERFORM BUILD-DATE-RANGE
    IF WS-MESSAGE NOT = SPACES
        DISPLAY WS-MESSAGE
        GOBACK
    END-IF
    DISPLAY "Report Type : " FUNCTION TRIM(WS-REPORT-NAME)
    DISPLAY "Start Date  : " WS-START-DATE
    DISPLAY "End Date    : " WS-END-DATE
    DISPLAY "Confirm submit (Y/N): " WITH NO ADVANCING
    ACCEPT WS-CONFIRM
    IF FUNCTION UPPER-CASE(FUNCTION TRIM(WS-CONFIRM))(1:1) NOT = "Y"
        DISPLAY "Report request cancelled."
        GOBACK
    END-IF
    PERFORM WRITE-DATEPARM-FILE
    PERFORM APPEND-REQUEST-FILE
    DISPLAY FUNCTION TRIM(WS-REPORT-NAME)
        " report request created."
    DISPLAY "DATEPARM file updated for batch report processing."
    GOBACK.

INITIALIZE-PATHS.
    ACCEPT WS-REQUEST-PATH FROM ENVIRONMENT "CARDDEMO_REPORT_REQUEST_PATH"
    IF WS-REQUEST-PATH = SPACES
        MOVE "app/data/ASCII/tranrept_requests.txt" TO WS-REQUEST-PATH
    END-IF
    ACCEPT WS-DATEPARM-PATH FROM ENVIRONMENT "CARDDEMO_DATEPARM_PATH"
    IF WS-DATEPARM-PATH = SPACES
        MOVE "app/data/ASCII/dateparm.txt" TO WS-DATEPARM-PATH
    END-IF.

PROMPT-FOR-REPORT.
    DISPLAY SPACE
    DISPLAY "Transaction Report Launcher"
    DISPLAY "Enter report type: M=Monthly, Y=Yearly, C=Custom"
    DISPLAY "Report Type: " WITH NO ADVANCING
    ACCEPT WS-REPORT-CHOICE
    MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-REPORT-CHOICE))
        TO WS-REPORT-CHOICE.

BUILD-DATE-RANGE.
    MOVE SPACES TO WS-MESSAGE
    EVALUATE WS-REPORT-CHOICE(1:1)
        WHEN "M"
            MOVE "Monthly" TO WS-REPORT-NAME
            PERFORM BUILD-MONTHLY-RANGE
        WHEN "Y"
            MOVE "Yearly" TO WS-REPORT-NAME
            PERFORM BUILD-YEARLY-RANGE
        WHEN "C"
            MOVE "Custom" TO WS-REPORT-NAME
            PERFORM BUILD-CUSTOM-RANGE
        WHEN OTHER
            MOVE "Select a valid report type: M, Y, or C." TO WS-MESSAGE
    END-EVALUATE.

BUILD-MONTHLY-RANGE.
    MOVE FUNCTION CURRENT-DATE TO WS-CURRENT-DATE-RAW
    MOVE WS-CURRENT-DATE-RAW(1:4) TO WS-START-DATE-YYYY
    MOVE WS-CURRENT-DATE-RAW(5:2) TO WS-START-DATE-MM
    MOVE "01" TO WS-START-DATE-DD
    MOVE FUNCTION NUMVAL(WS-CURRENT-DATE-RAW(5:2)) TO WS-CURRENT-MONTH
    MOVE FUNCTION NUMVAL(WS-CURRENT-DATE-RAW(1:4)) TO WS-NEXT-YEAR
    ADD 1 TO WS-CURRENT-MONTH GIVING WS-NEXT-MONTH
    IF WS-NEXT-MONTH > 12
        MOVE 1 TO WS-NEXT-MONTH
        ADD 1 TO WS-NEXT-YEAR
    END-IF
    COMPUTE WS-END-DATE-N =
        FUNCTION DATE-OF-INTEGER(
            FUNCTION INTEGER-OF-DATE(WS-NEXT-YEAR * 10000 + WS-NEXT-MONTH * 100 + 1) - 1)
    MOVE WS-END-YEAR-N TO WS-END-DATE-YYYY
    MOVE WS-END-MONTH-N TO WS-END-DATE-MM
    MOVE WS-END-DAY-N TO WS-END-DATE-DD.

BUILD-YEARLY-RANGE.
    MOVE FUNCTION CURRENT-DATE TO WS-CURRENT-DATE-RAW
    MOVE WS-CURRENT-DATE-RAW(1:4) TO WS-START-DATE-YYYY WS-END-DATE-YYYY
    MOVE "01" TO WS-START-DATE-MM WS-START-DATE-DD
    MOVE "12" TO WS-END-DATE-MM
    MOVE "31" TO WS-END-DATE-DD.

BUILD-CUSTOM-RANGE.
    DISPLAY "Start Month (MM): " WITH NO ADVANCING
    ACCEPT WS-START-MONTH
    DISPLAY "Start Day (DD): " WITH NO ADVANCING
    ACCEPT WS-START-DAY
    DISPLAY "Start Year (YYYY): " WITH NO ADVANCING
    ACCEPT WS-START-YEAR
    DISPLAY "End Month (MM): " WITH NO ADVANCING
    ACCEPT WS-END-MONTH
    DISPLAY "End Day (DD): " WITH NO ADVANCING
    ACCEPT WS-END-DAY
    DISPLAY "End Year (YYYY): " WITH NO ADVANCING
    ACCEPT WS-END-YEAR
    MOVE WS-START-YEAR TO WS-START-DATE-YYYY
    MOVE WS-START-MONTH TO WS-START-DATE-MM
    MOVE WS-START-DAY TO WS-START-DATE-DD
    MOVE WS-END-YEAR TO WS-END-DATE-YYYY
    MOVE WS-END-MONTH TO WS-END-DATE-MM
    MOVE WS-END-DAY TO WS-END-DATE-DD
    MOVE WS-START-DATE TO WS-DATE-CHECK
    PERFORM VALIDATE-DATE
    IF WS-MESSAGE = SPACES
        MOVE WS-END-DATE TO WS-DATE-CHECK
        PERFORM VALIDATE-DATE
        IF WS-MESSAGE = SPACES
            IF WS-START-DATE > WS-END-DATE
                MOVE "Start date must not be after end date." TO WS-MESSAGE
            END-IF
        ELSE
            MOVE "End Date - Not a valid date..." TO WS-MESSAGE
        END-IF
    ELSE
        MOVE "Start Date - Not a valid date..." TO WS-MESSAGE
    END-IF.

VALIDATE-DATE.
    IF FUNCTION TRIM(WS-DATE-CHECK) = SPACES
        MOVE "Invalid date." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF WS-DATE-CHECK(1:4) IS NOT NUMERIC
        OR WS-DATE-CHECK(5:1) NOT = "-"
        OR WS-DATE-CHECK(6:2) IS NOT NUMERIC
        OR WS-DATE-CHECK(8:1) NOT = "-"
        OR WS-DATE-CHECK(9:2) IS NOT NUMERIC
        MOVE "Invalid date." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    COMPUTE WS-YEAR-N = FUNCTION NUMVAL(WS-DATE-CHECK(1:4))
    COMPUTE WS-MONTH-N = FUNCTION NUMVAL(WS-DATE-CHECK(6:2))
    COMPUTE WS-DAY-N = FUNCTION NUMVAL(WS-DATE-CHECK(9:2))
    IF WS-MONTH-N < 1 OR WS-MONTH-N > 12 OR WS-DAY-N < 1 OR WS-DAY-N > 31
        MOVE "Invalid date." TO WS-MESSAGE
    END-IF.

WRITE-DATEPARM-FILE.
    OPEN OUTPUT DATEPARM-FILE
    IF WS-DATEPARM-STATUS NOT = "00"
        DISPLAY "Unable to write DATEPARM file. Status: " WS-DATEPARM-STATUS
        GOBACK
    END-IF
    MOVE SPACES TO WS-DATEPARM-LINE
    STRING WS-START-DATE " " WS-END-DATE
        DELIMITED BY SIZE INTO WS-DATEPARM-LINE
    WRITE DATEPARM-RECORD FROM WS-DATEPARM-LINE
    CLOSE DATEPARM-FILE.

APPEND-REQUEST-FILE.
    STRING
        FUNCTION CURRENT-DATE(1:4) "-" FUNCTION CURRENT-DATE(5:2) "-"
        FUNCTION CURRENT-DATE(7:2)
        DELIMITED BY SIZE INTO WS-TIMESTAMP-DATE
    STRING
        FUNCTION CURRENT-DATE(9:2) ":" FUNCTION CURRENT-DATE(11:2) ":"
        FUNCTION CURRENT-DATE(13:2)
        DELIMITED BY SIZE INTO WS-TIMESTAMP-TIME
    STRING WS-TIMESTAMP-DATE " " WS-TIMESTAMP-TIME
        DELIMITED BY SIZE INTO WS-TIMESTAMP
    OPEN EXTEND REQUEST-FILE
    IF WS-REQUEST-STATUS = "35"
        OPEN OUTPUT REQUEST-FILE
        CLOSE REQUEST-FILE
        OPEN EXTEND REQUEST-FILE
    END-IF
    IF WS-REQUEST-STATUS NOT = "00"
        DISPLAY "Unable to append report request file. Status: " WS-REQUEST-STATUS
        GOBACK
    END-IF
    STRING
        WS-TIMESTAMP DELIMITED BY SIZE
        "|" DELIMITED BY SIZE
        CDEMO-USER-ID DELIMITED BY SIZE
        "|" DELIMITED BY SIZE
        FUNCTION TRIM(WS-REPORT-NAME) DELIMITED BY SIZE
        "|" DELIMITED BY SIZE
        WS-START-DATE DELIMITED BY SIZE
        "|" DELIMITED BY SIZE
        WS-END-DATE DELIMITED BY SIZE
        INTO WS-REQUEST-LINE
    WRITE REQUEST-RECORD FROM WS-REQUEST-LINE
    CLOSE REQUEST-FILE.
