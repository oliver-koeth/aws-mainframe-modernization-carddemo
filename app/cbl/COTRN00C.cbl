>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. COTRN00C.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT TRANSACTION-FILE ASSIGN TO DYNAMIC WS-TRANSACTION-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-TRANSACTION-STATUS.

DATA DIVISION.
FILE SECTION.
FD TRANSACTION-FILE.
01 TRANSACTION-RAW-RECORD            PIC X(350).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-TRANSACTION-PATH            PIC X(256) VALUE SPACES.
   05 WS-TRANSACTION-STATUS          PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-END-OF-FILE                 PIC X VALUE "N".
      88 END-OF-FILE                             VALUE "Y".
      88 MORE-RECORDS                            VALUE "N".
   05 WS-DONE                        PIC X VALUE "N".
      88 LIST-DONE                               VALUE "Y".
      88 LIST-ACTIVE                             VALUE "N".

01 WS-FILTERS.
   05 WS-FILTER-TRAN-ID              PIC X(16) VALUE SPACES.
   05 WS-FILTER-CARD-NUM             PIC X(16) VALUE SPACES.
   05 WS-NAV-CHOICE                  PIC X(10) VALUE SPACES.

01 WS-COUNTERS.
   05 WS-TRANSACTION-COUNT           PIC 9(04) VALUE 0.
   05 WS-FILTERED-COUNT              PIC 9(04) VALUE 0.
   05 WS-PAGE-SIZE                   PIC 9(02) VALUE 10.
   05 WS-PAGE-START                  PIC 9(04) VALUE 1.
   05 WS-PAGE-END                    PIC 9(04) VALUE 0.
   05 WS-IDX                         PIC 9(04) VALUE 0.
   05 WS-DISPLAY-IDX                 PIC 9(04) VALUE 0.
   05 WS-AMOUNT-NUMERIC              PIC 9(11) VALUE 0.

01 WS-TRANSACTIONS.
   05 WS-TRANSACTION-ENTRY OCCURS 1000 TIMES.
      10 WS-TRANSACTION-LINE         PIC X(350).

01 WS-FILTERED-INDICES.
   05 WS-FILTERED-INDEX OCCURS 1000 TIMES PIC 9(04).

01 WS-DISPLAY.
   05 WS-AMOUNT-RAW                  PIC X(11) VALUE SPACES.
   05 WS-AMOUNT-SIGN                 PIC X(01) VALUE SPACE.
   05 WS-AMOUNT-LAST-DIGIT           PIC X(01) VALUE SPACE.
   05 WS-AMOUNT-VALUE                PIC S9(9)V99 VALUE 0.
   05 WS-AMOUNT-DISPLAY              PIC -ZZZZZZZ9.99 VALUE ZERO.
   05 WS-DATE-DISPLAY                PIC X(10) VALUE SPACES.

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATH
    PERFORM LOAD-TRANSACTIONS
    PERFORM PROMPT-FILTERS
    PERFORM BUILD-FILTERED-LIST
    IF WS-FILTERED-COUNT = 0
        DISPLAY "No transactions found for the supplied filters."
        GOBACK
    END-IF

    SET LIST-ACTIVE TO TRUE
    PERFORM UNTIL LIST-DONE
        PERFORM DISPLAY-PAGE
        DISPLAY "Enter N(ext), P(revious), or Q(uit): " WITH NO ADVANCING
        ACCEPT WS-NAV-CHOICE
        MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-NAV-CHOICE)) TO WS-NAV-CHOICE
        EVALUATE WS-NAV-CHOICE(1:1)
            WHEN "N"
                IF WS-PAGE-END < WS-FILTERED-COUNT
                    ADD WS-PAGE-SIZE TO WS-PAGE-START
                END-IF
            WHEN "P"
                IF WS-PAGE-START > WS-PAGE-SIZE
                    SUBTRACT WS-PAGE-SIZE FROM WS-PAGE-START
                ELSE
                    MOVE 1 TO WS-PAGE-START
                END-IF
            WHEN "Q"
                SET LIST-DONE TO TRUE
            WHEN OTHER
                CONTINUE
        END-EVALUATE
    END-PERFORM
    GOBACK.

INITIALIZE-PATH.
    ACCEPT WS-TRANSACTION-PATH FROM ENVIRONMENT "CARDDEMO_TRAN_PATH"
    IF WS-TRANSACTION-PATH = SPACES
        MOVE "app/data/ASCII/dailytran.txt" TO WS-TRANSACTION-PATH
    END-IF.

LOAD-TRANSACTIONS.
    MOVE 0 TO WS-TRANSACTION-COUNT
    SET MORE-RECORDS TO TRUE
    OPEN INPUT TRANSACTION-FILE
    IF WS-TRANSACTION-STATUS NOT = "00"
        DISPLAY "Unable to open transaction file. Status: " WS-TRANSACTION-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ TRANSACTION-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                ADD 1 TO WS-TRANSACTION-COUNT
                MOVE TRANSACTION-RAW-RECORD TO
                    WS-TRANSACTION-LINE(WS-TRANSACTION-COUNT)
        END-READ
    END-PERFORM
    CLOSE TRANSACTION-FILE.

PROMPT-FILTERS.
    DISPLAY SPACE
    DISPLAY "Transaction List"
    DISPLAY "Transaction ID filter (optional): " WITH NO ADVANCING
    ACCEPT WS-FILTER-TRAN-ID
    DISPLAY "Card Number filter (optional): " WITH NO ADVANCING
    ACCEPT WS-FILTER-CARD-NUM.

BUILD-FILTERED-LIST.
    MOVE 0 TO WS-FILTERED-COUNT
    MOVE 1 TO WS-PAGE-START
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-TRANSACTION-COUNT
        IF (FUNCTION TRIM(WS-FILTER-TRAN-ID) = SPACES
           OR WS-TRANSACTION-LINE(WS-IDX)(1:16) = WS-FILTER-TRAN-ID)
           AND
           (FUNCTION TRIM(WS-FILTER-CARD-NUM) = SPACES
            OR WS-TRANSACTION-LINE(WS-IDX)(263:16) = WS-FILTER-CARD-NUM)
            ADD 1 TO WS-FILTERED-COUNT
            MOVE WS-IDX TO WS-FILTERED-INDEX(WS-FILTERED-COUNT)
        END-IF
    END-PERFORM.

DISPLAY-PAGE.
    DISPLAY SPACE
    DISPLAY "Transaction List"
    DISPLAY "Tran ID           Date        Amount         Card Number        Description"
    DISPLAY "----------------  ----------  -------------  ----------------  ------------------------------"
    COMPUTE WS-PAGE-END = WS-PAGE-START + WS-PAGE-SIZE - 1
    IF WS-PAGE-END > WS-FILTERED-COUNT
        MOVE WS-FILTERED-COUNT TO WS-PAGE-END
    END-IF
    PERFORM VARYING WS-IDX FROM WS-PAGE-START BY 1 UNTIL WS-IDX > WS-PAGE-END
        MOVE WS-FILTERED-INDEX(WS-IDX) TO WS-DISPLAY-IDX
        PERFORM FORMAT-TRANSACTION-DISPLAY
        DISPLAY WS-TRANSACTION-LINE(WS-DISPLAY-IDX)(1:16) "  "
            WS-DATE-DISPLAY "  "
            WS-AMOUNT-DISPLAY "  "
            WS-TRANSACTION-LINE(WS-DISPLAY-IDX)(263:16) "  "
            FUNCTION TRIM(WS-TRANSACTION-LINE(WS-DISPLAY-IDX)(33:30))
    END-PERFORM
    DISPLAY "Showing " WS-PAGE-START " to " WS-PAGE-END
        " of " WS-FILTERED-COUNT
    DISPLAY "Transaction detail selection remains in Slice 8.".

FORMAT-TRANSACTION-DISPLAY.
    MOVE WS-TRANSACTION-LINE(WS-DISPLAY-IDX)(133:11) TO WS-AMOUNT-RAW
    MOVE WS-TRANSACTION-LINE(WS-DISPLAY-IDX)(279:10) TO WS-DATE-DISPLAY
    PERFORM DECODE-AMOUNT.

DECODE-AMOUNT.
    MOVE 0 TO WS-AMOUNT-NUMERIC
    MOVE "+" TO WS-AMOUNT-SIGN
    MOVE WS-AMOUNT-RAW(11:1) TO WS-AMOUNT-LAST-DIGIT
    EVALUATE WS-AMOUNT-LAST-DIGIT
        WHEN "{"
            MOVE "0" TO WS-AMOUNT-RAW(11:1)
        WHEN "A"
            MOVE "1" TO WS-AMOUNT-RAW(11:1)
        WHEN "B"
            MOVE "2" TO WS-AMOUNT-RAW(11:1)
        WHEN "C"
            MOVE "3" TO WS-AMOUNT-RAW(11:1)
        WHEN "D"
            MOVE "4" TO WS-AMOUNT-RAW(11:1)
        WHEN "E"
            MOVE "5" TO WS-AMOUNT-RAW(11:1)
        WHEN "F"
            MOVE "6" TO WS-AMOUNT-RAW(11:1)
        WHEN "G"
            MOVE "7" TO WS-AMOUNT-RAW(11:1)
        WHEN "H"
            MOVE "8" TO WS-AMOUNT-RAW(11:1)
        WHEN "I"
            MOVE "9" TO WS-AMOUNT-RAW(11:1)
        WHEN "}"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "0" TO WS-AMOUNT-RAW(11:1)
        WHEN "J"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "1" TO WS-AMOUNT-RAW(11:1)
        WHEN "K"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "2" TO WS-AMOUNT-RAW(11:1)
        WHEN "L"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "3" TO WS-AMOUNT-RAW(11:1)
        WHEN "M"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "4" TO WS-AMOUNT-RAW(11:1)
        WHEN "N"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "5" TO WS-AMOUNT-RAW(11:1)
        WHEN "O"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "6" TO WS-AMOUNT-RAW(11:1)
        WHEN "P"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "7" TO WS-AMOUNT-RAW(11:1)
        WHEN "Q"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "8" TO WS-AMOUNT-RAW(11:1)
        WHEN "R"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "9" TO WS-AMOUNT-RAW(11:1)
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    COMPUTE WS-AMOUNT-NUMERIC = FUNCTION NUMVAL(WS-AMOUNT-RAW)
    COMPUTE WS-AMOUNT-VALUE = WS-AMOUNT-NUMERIC / 100
    IF WS-AMOUNT-SIGN = "-"
        COMPUTE WS-AMOUNT-VALUE = WS-AMOUNT-VALUE * -1
    END-IF
    MOVE WS-AMOUNT-VALUE TO WS-AMOUNT-DISPLAY.
