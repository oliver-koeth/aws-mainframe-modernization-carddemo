>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. COTRN01C.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT TRANSACTION-FILE ASSIGN TO DYNAMIC WS-TRANSACTION-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-TRANSACTION-STATUS.

DATA DIVISION.
FILE SECTION.
FD TRANSACTION-FILE.
01 TRANSACTION-RAW-RECORD            PIC X(350).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-TRANSACTION-PATH            PIC X(256) VALUE SPACES.
   05 WS-TRANSACTION-STATUS          PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-END-OF-FILE                 PIC X VALUE "N".
      88 END-OF-FILE                             VALUE "Y".
      88 MORE-RECORDS                            VALUE "N".
   05 WS-FOUND                       PIC X VALUE "N".
      88 TRANSACTION-FOUND                       VALUE "Y".
      88 TRANSACTION-NOT-FOUND                   VALUE "N".

01 WS-SEARCH.
   05 WS-SEARCH-TRAN-ID              PIC X(16) VALUE SPACES.

01 WS-CURRENT.
   05 WS-CURRENT-LINE                PIC X(350) VALUE SPACES.

01 WS-DISPLAY.
   05 WS-AMOUNT-RAW                  PIC X(11) VALUE SPACES.
   05 WS-AMOUNT-SIGN                 PIC X(01) VALUE SPACE.
   05 WS-AMOUNT-LAST-DIGIT           PIC X(01) VALUE SPACE.
   05 WS-AMOUNT-NUMERIC              PIC 9(11) VALUE 0.
   05 WS-AMOUNT-VALUE                PIC S9(9)V99 VALUE 0.
   05 WS-AMOUNT-DISPLAY              PIC -ZZZZZZZ9.99 VALUE ZERO.
   05 WS-TYPE-CODE                   PIC X(02) VALUE SPACES.
   05 WS-CATEGORY-CODE               PIC X(04) VALUE SPACES.
   05 WS-SOURCE                      PIC X(10) VALUE SPACES.
   05 WS-DESCRIPTION                 PIC X(100) VALUE SPACES.
   05 WS-MERCHANT-ID                 PIC X(09) VALUE SPACES.
   05 WS-MERCHANT-NAME               PIC X(50) VALUE SPACES.
   05 WS-MERCHANT-CITY               PIC X(50) VALUE SPACES.
   05 WS-MERCHANT-ZIP                PIC X(10) VALUE SPACES.
   05 WS-CARD-NUM                    PIC X(16) VALUE SPACES.
   05 WS-ORIG-TS                     PIC X(26) VALUE SPACES.
   05 WS-PROC-TS                     PIC X(26) VALUE SPACES.

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATH
    PERFORM PROMPT-FOR-LOOKUP
    IF FUNCTION TRIM(WS-SEARCH-TRAN-ID) = SPACES
        DISPLAY "You must enter a transaction ID."
        GOBACK
    END-IF
    PERFORM FIND-TRANSACTION
    IF TRANSACTION-NOT-FOUND
        DISPLAY "Transaction view failed: transaction not found."
        GOBACK
    END-IF
    PERFORM EXTRACT-FIELDS
    PERFORM DISPLAY-TRANSACTION
    GOBACK.

INITIALIZE-PATH.
    ACCEPT WS-TRANSACTION-PATH FROM ENVIRONMENT "CARDDEMO_TRAN_PATH"
    IF WS-TRANSACTION-PATH = SPACES
        MOVE "app/data/ASCII/dailytran.txt" TO WS-TRANSACTION-PATH
    END-IF.

PROMPT-FOR-LOOKUP.
    DISPLAY SPACE
    DISPLAY "Transaction View"
    DISPLAY "Transaction ID (16 characters): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-TRAN-ID.

FIND-TRANSACTION.
    SET TRANSACTION-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT TRANSACTION-FILE
    IF WS-TRANSACTION-STATUS NOT = "00"
        DISPLAY "Unable to open transaction file. Status: "
            WS-TRANSACTION-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE OR TRANSACTION-FOUND
        READ TRANSACTION-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF TRANSACTION-RAW-RECORD(1:16) = WS-SEARCH-TRAN-ID
                    MOVE TRANSACTION-RAW-RECORD TO WS-CURRENT-LINE
                    SET TRANSACTION-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE TRANSACTION-FILE.

EXTRACT-FIELDS.
    MOVE WS-CURRENT-LINE(17:2) TO WS-TYPE-CODE
    MOVE WS-CURRENT-LINE(19:4) TO WS-CATEGORY-CODE
    MOVE WS-CURRENT-LINE(23:10) TO WS-SOURCE
    MOVE WS-CURRENT-LINE(33:100) TO WS-DESCRIPTION
    MOVE WS-CURRENT-LINE(133:11) TO WS-AMOUNT-RAW
    MOVE WS-CURRENT-LINE(144:9) TO WS-MERCHANT-ID
    MOVE WS-CURRENT-LINE(153:50) TO WS-MERCHANT-NAME
    MOVE WS-CURRENT-LINE(203:50) TO WS-MERCHANT-CITY
    MOVE WS-CURRENT-LINE(253:10) TO WS-MERCHANT-ZIP
    MOVE WS-CURRENT-LINE(263:16) TO WS-CARD-NUM
    MOVE WS-CURRENT-LINE(279:26) TO WS-ORIG-TS
    MOVE WS-CURRENT-LINE(305:26) TO WS-PROC-TS
    PERFORM DECODE-AMOUNT.

DECODE-AMOUNT.
    MOVE 0 TO WS-AMOUNT-NUMERIC
    MOVE "+" TO WS-AMOUNT-SIGN
    MOVE WS-AMOUNT-RAW(11:1) TO WS-AMOUNT-LAST-DIGIT
    EVALUATE WS-AMOUNT-LAST-DIGIT
        WHEN "{"
            MOVE "0" TO WS-AMOUNT-RAW(11:1)
        WHEN "A"
            MOVE "1" TO WS-AMOUNT-RAW(11:1)
        WHEN "B"
            MOVE "2" TO WS-AMOUNT-RAW(11:1)
        WHEN "C"
            MOVE "3" TO WS-AMOUNT-RAW(11:1)
        WHEN "D"
            MOVE "4" TO WS-AMOUNT-RAW(11:1)
        WHEN "E"
            MOVE "5" TO WS-AMOUNT-RAW(11:1)
        WHEN "F"
            MOVE "6" TO WS-AMOUNT-RAW(11:1)
        WHEN "G"
            MOVE "7" TO WS-AMOUNT-RAW(11:1)
        WHEN "H"
            MOVE "8" TO WS-AMOUNT-RAW(11:1)
        WHEN "I"
            MOVE "9" TO WS-AMOUNT-RAW(11:1)
        WHEN "}"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "0" TO WS-AMOUNT-RAW(11:1)
        WHEN "J"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "1" TO WS-AMOUNT-RAW(11:1)
        WHEN "K"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "2" TO WS-AMOUNT-RAW(11:1)
        WHEN "L"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "3" TO WS-AMOUNT-RAW(11:1)
        WHEN "M"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "4" TO WS-AMOUNT-RAW(11:1)
        WHEN "N"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "5" TO WS-AMOUNT-RAW(11:1)
        WHEN "O"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "6" TO WS-AMOUNT-RAW(11:1)
        WHEN "P"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "7" TO WS-AMOUNT-RAW(11:1)
        WHEN "Q"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "8" TO WS-AMOUNT-RAW(11:1)
        WHEN "R"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "9" TO WS-AMOUNT-RAW(11:1)
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    COMPUTE WS-AMOUNT-NUMERIC = FUNCTION NUMVAL(WS-AMOUNT-RAW)
    COMPUTE WS-AMOUNT-VALUE = WS-AMOUNT-NUMERIC / 100
    IF WS-AMOUNT-SIGN = "-"
        COMPUTE WS-AMOUNT-VALUE = WS-AMOUNT-VALUE * -1
    END-IF
    MOVE WS-AMOUNT-VALUE TO WS-AMOUNT-DISPLAY.

DISPLAY-TRANSACTION.
    DISPLAY SPACE
    DISPLAY "Transaction Details"
    DISPLAY "Transaction ID  : " WS-SEARCH-TRAN-ID
    DISPLAY "Type Code       : " WS-TYPE-CODE
    DISPLAY "Category Code   : " WS-CATEGORY-CODE
    DISPLAY "Source          : " FUNCTION TRIM(WS-SOURCE)
    DISPLAY "Amount          : " WS-AMOUNT-DISPLAY
    DISPLAY "Description     : " FUNCTION TRIM(WS-DESCRIPTION)
    DISPLAY "Card Number     : " WS-CARD-NUM
    DISPLAY "Merchant ID     : " WS-MERCHANT-ID
    DISPLAY "Merchant Name   : " FUNCTION TRIM(WS-MERCHANT-NAME)
    DISPLAY "Merchant City   : " FUNCTION TRIM(WS-MERCHANT-CITY)
    DISPLAY "Merchant ZIP    : " FUNCTION TRIM(WS-MERCHANT-ZIP)
    DISPLAY "Original TS     : " FUNCTION TRIM(WS-ORIG-TS)
    IF FUNCTION TRIM(WS-PROC-TS) = SPACES
        DISPLAY "Processed TS    : " "(not populated in flat-file source)"
    ELSE
        DISPLAY "Processed TS    : " FUNCTION TRIM(WS-PROC-TS)
    END-IF.
