>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. COACTUPC.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT ACCOUNT-FILE ASSIGN TO DYNAMIC WS-ACCOUNT-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-ACCOUNT-STATUS.
    SELECT CUSTOMER-FILE ASSIGN TO DYNAMIC WS-CUSTOMER-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-CUSTOMER-STATUS.
    SELECT XREF-FILE ASSIGN TO DYNAMIC WS-XREF-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-XREF-STATUS.

DATA DIVISION.
FILE SECTION.
FD ACCOUNT-FILE.
01 ACCOUNT-RAW-RECORD PIC X(300).

FD CUSTOMER-FILE.
01 CUSTOMER-RAW-RECORD PIC X(500).

FD XREF-FILE.
01 XREF-RAW-RECORD PIC X(50).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-ACCOUNT-PATH              PIC X(256) VALUE SPACES.
   05 WS-CUSTOMER-PATH             PIC X(256) VALUE SPACES.
   05 WS-XREF-PATH                 PIC X(256) VALUE SPACES.
   05 WS-ACCOUNT-STATUS            PIC X(02) VALUE SPACES.
   05 WS-CUSTOMER-STATUS           PIC X(02) VALUE SPACES.
   05 WS-XREF-STATUS               PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-END-OF-FILE               PIC X VALUE "N".
      88 END-OF-FILE                           VALUE "Y".
      88 MORE-RECORDS                          VALUE "N".
   05 WS-ACCOUNT-FOUND             PIC X VALUE "N".
      88 ACCOUNT-FOUND                         VALUE "Y".
      88 ACCOUNT-NOT-FOUND                     VALUE "N".
   05 WS-XREF-FOUND                PIC X VALUE "N".
      88 XREF-FOUND                            VALUE "Y".
      88 XREF-NOT-FOUND                        VALUE "N".
   05 WS-CUSTOMER-FOUND            PIC X VALUE "N".
      88 CUSTOMER-FOUND                        VALUE "Y".
      88 CUSTOMER-NOT-FOUND                    VALUE "N".
   05 WS-ACCOUNT-CHANGED           PIC X VALUE "N".
      88 ACCOUNT-CHANGED                       VALUE "Y".
      88 ACCOUNT-UNCHANGED                     VALUE "N".
   05 WS-CUSTOMER-CHANGED          PIC X VALUE "N".
      88 CUSTOMER-CHANGED                      VALUE "Y".
      88 CUSTOMER-UNCHANGED                    VALUE "N".

01 WS-SEARCH.
   05 WS-SEARCH-ACCOUNT-ID         PIC X(11) VALUE SPACES.
   05 WS-SEARCH-CARD-NUM           PIC X(16) VALUE SPACES.

01 WS-IDENTIFIERS.
   05 WS-XREF-CARD-NUM             PIC X(16).
   05 WS-XREF-CUST-ID              PIC X(09).
   05 WS-XREF-ACCT-ID              PIC X(11).

01 WS-INDICES.
   05 WS-ACCOUNT-COUNT             PIC 9(04) VALUE 0.
   05 WS-CUSTOMER-COUNT            PIC 9(04) VALUE 0.
   05 WS-ACCOUNT-IDX               PIC 9(04) VALUE 0.
   05 WS-CUSTOMER-IDX              PIC 9(04) VALUE 0.
   05 WS-IDX                       PIC 9(04) VALUE 0.

01 WS-ACCOUNT-TABLE.
   05 WS-ACCOUNT-ENTRY OCCURS 500 TIMES.
      10 WS-ACCOUNT-LINE           PIC X(300).

01 WS-CUSTOMER-TABLE.
   05 WS-CUSTOMER-ENTRY OCCURS 500 TIMES.
      10 WS-CUSTOMER-LINE          PIC X(500).

01 WS-CURRENT-DATA.
   05 WS-CURR-ACCT-ID              PIC X(11).
   05 WS-CURR-ACCT-STATUS          PIC X(01).
   05 WS-CURR-OPEN-DATE            PIC X(10).
   05 WS-CURR-EXP-DATE             PIC X(10).
   05 WS-CURR-REISSUE-DATE         PIC X(10).
   05 WS-CURR-GROUP-ID             PIC X(10).
   05 WS-CURR-CUST-ID              PIC X(09).
   05 WS-CURR-FIRST-NAME           PIC X(25).
   05 WS-CURR-MIDDLE-NAME          PIC X(25).
   05 WS-CURR-LAST-NAME            PIC X(25).
   05 WS-CURR-ADDR-LINE-1          PIC X(50).
   05 WS-CURR-ADDR-LINE-2          PIC X(50).
   05 WS-CURR-ADDR-LINE-3          PIC X(50).
   05 WS-CURR-STATE                PIC X(02).
   05 WS-CURR-COUNTRY              PIC X(03).
   05 WS-CURR-ZIP                  PIC X(10).
   05 WS-CURR-PHONE-1              PIC X(15).
   05 WS-CURR-PHONE-2              PIC X(15).

01 WS-INPUT.
   05 WS-INPUT-BUFFER              PIC X(80) VALUE SPACES.
   05 WS-WORK-NAME                 PIC X(80) VALUE SPACES.
   05 WS-WORK-DATE                 PIC X(10) VALUE SPACES.

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATHS
    PERFORM LOAD-ACCOUNT-TABLE
    PERFORM LOAD-CUSTOMER-TABLE
    PERFORM PROMPT-FOR-LOOKUP
    PERFORM FIND-RELATED-RECORDS
    IF ACCOUNT-NOT-FOUND
        DISPLAY "Account update failed: account not found."
        GOBACK
    END-IF
    PERFORM DISPLAY-CURRENT-VALUES
    PERFORM PROMPT-FOR-UPDATES
    PERFORM SAVE-CHANGES
    DISPLAY "Account update complete."
    GOBACK.

INITIALIZE-PATHS.
    ACCEPT WS-ACCOUNT-PATH FROM ENVIRONMENT "CARDDEMO_ACCT_PATH"
    IF WS-ACCOUNT-PATH = SPACES
        MOVE "app/data/ASCII/acctdata.txt" TO WS-ACCOUNT-PATH
    END-IF
    ACCEPT WS-CUSTOMER-PATH FROM ENVIRONMENT "CARDDEMO_CUST_PATH"
    IF WS-CUSTOMER-PATH = SPACES
        MOVE "app/data/ASCII/custdata.txt" TO WS-CUSTOMER-PATH
    END-IF
    ACCEPT WS-XREF-PATH FROM ENVIRONMENT "CARDDEMO_XREF_PATH"
    IF WS-XREF-PATH = SPACES
        MOVE "app/data/ASCII/cardxref.txt" TO WS-XREF-PATH
    END-IF.

LOAD-ACCOUNT-TABLE.
    MOVE 0 TO WS-ACCOUNT-COUNT
    SET MORE-RECORDS TO TRUE
    OPEN INPUT ACCOUNT-FILE
    IF WS-ACCOUNT-STATUS NOT = "00"
        DISPLAY "Unable to open account file. Status: " WS-ACCOUNT-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ ACCOUNT-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                ADD 1 TO WS-ACCOUNT-COUNT
                MOVE ACCOUNT-RAW-RECORD TO WS-ACCOUNT-LINE(WS-ACCOUNT-COUNT)
        END-READ
    END-PERFORM
    CLOSE ACCOUNT-FILE.

LOAD-CUSTOMER-TABLE.
    SET MORE-RECORDS TO TRUE
    MOVE 0 TO WS-CUSTOMER-COUNT
    OPEN INPUT CUSTOMER-FILE
    IF WS-CUSTOMER-STATUS NOT = "00"
        DISPLAY "Unable to open customer file. Status: " WS-CUSTOMER-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ CUSTOMER-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                ADD 1 TO WS-CUSTOMER-COUNT
                MOVE CUSTOMER-RAW-RECORD TO WS-CUSTOMER-LINE(WS-CUSTOMER-COUNT)
        END-READ
    END-PERFORM
    CLOSE CUSTOMER-FILE.

PROMPT-FOR-LOOKUP.
    DISPLAY SPACE
    DISPLAY "Account Update"
    DISPLAY "Lookup by account ID or card number."
    DISPLAY "Account ID (11 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-ACCOUNT-ID
    DISPLAY "Card Number (16 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-CARD-NUM.

FIND-RELATED-RECORDS.
    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
        AND FUNCTION TRIM(WS-SEARCH-CARD-NUM) = SPACES
        DISPLAY "You must enter an account ID or a card number."
        GOBACK
    END-IF

    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
        PERFORM FIND-XREF-BY-CARD
        IF XREF-FOUND
            MOVE WS-XREF-ACCT-ID TO WS-SEARCH-ACCOUNT-ID
        END-IF
    ELSE
        PERFORM FIND-XREF-BY-ACCOUNT
    END-IF

    PERFORM FIND-ACCOUNT-IN-TABLE
    IF XREF-FOUND
        PERFORM FIND-CUSTOMER-IN-TABLE
    END-IF.

FIND-XREF-BY-CARD.
    SET XREF-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(1:16) = WS-SEARCH-CARD-NUM
                    MOVE XREF-RAW-RECORD(1:16) TO WS-XREF-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-XREF-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-XREF-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

FIND-XREF-BY-ACCOUNT.
    SET XREF-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(26:11) = WS-SEARCH-ACCOUNT-ID
                    MOVE XREF-RAW-RECORD(1:16) TO WS-XREF-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-XREF-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-XREF-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

FIND-ACCOUNT-IN-TABLE.
    SET ACCOUNT-NOT-FOUND TO TRUE
    MOVE 0 TO WS-ACCOUNT-IDX
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-ACCOUNT-COUNT
        IF WS-ACCOUNT-LINE(WS-IDX)(1:11) = WS-SEARCH-ACCOUNT-ID
            MOVE WS-IDX TO WS-ACCOUNT-IDX
            SET ACCOUNT-FOUND TO TRUE
            MOVE WS-ACCOUNT-LINE(WS-IDX)(1:11) TO WS-CURR-ACCT-ID
            MOVE WS-ACCOUNT-LINE(WS-IDX)(12:1) TO WS-CURR-ACCT-STATUS
            MOVE WS-ACCOUNT-LINE(WS-IDX)(49:10) TO WS-CURR-OPEN-DATE
            MOVE WS-ACCOUNT-LINE(WS-IDX)(59:10) TO WS-CURR-EXP-DATE
            MOVE WS-ACCOUNT-LINE(WS-IDX)(69:10) TO WS-CURR-REISSUE-DATE
            MOVE WS-ACCOUNT-LINE(WS-IDX)(113:10) TO WS-CURR-GROUP-ID
            EXIT PERFORM
        END-IF
    END-PERFORM.

FIND-CUSTOMER-IN-TABLE.
    SET CUSTOMER-NOT-FOUND TO TRUE
    MOVE 0 TO WS-CUSTOMER-IDX
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-CUSTOMER-COUNT
        IF WS-CUSTOMER-LINE(WS-IDX)(1:9) = WS-XREF-CUST-ID
            MOVE WS-IDX TO WS-CUSTOMER-IDX
            SET CUSTOMER-FOUND TO TRUE
            MOVE WS-CUSTOMER-LINE(WS-IDX)(1:9) TO WS-CURR-CUST-ID
            MOVE WS-CUSTOMER-LINE(WS-IDX)(10:25) TO WS-CURR-FIRST-NAME
            MOVE WS-CUSTOMER-LINE(WS-IDX)(35:25) TO WS-CURR-MIDDLE-NAME
            MOVE WS-CUSTOMER-LINE(WS-IDX)(60:25) TO WS-CURR-LAST-NAME
            MOVE WS-CUSTOMER-LINE(WS-IDX)(85:50) TO WS-CURR-ADDR-LINE-1
            MOVE WS-CUSTOMER-LINE(WS-IDX)(135:50) TO WS-CURR-ADDR-LINE-2
            MOVE WS-CUSTOMER-LINE(WS-IDX)(185:50) TO WS-CURR-ADDR-LINE-3
            MOVE WS-CUSTOMER-LINE(WS-IDX)(235:2) TO WS-CURR-STATE
            MOVE WS-CUSTOMER-LINE(WS-IDX)(237:3) TO WS-CURR-COUNTRY
            MOVE WS-CUSTOMER-LINE(WS-IDX)(240:10) TO WS-CURR-ZIP
            MOVE WS-CUSTOMER-LINE(WS-IDX)(250:15) TO WS-CURR-PHONE-1
            MOVE WS-CUSTOMER-LINE(WS-IDX)(265:15) TO WS-CURR-PHONE-2
            EXIT PERFORM
        END-IF
    END-PERFORM.

DISPLAY-CURRENT-VALUES.
    DISPLAY SPACE
    DISPLAY "Current Account Values"
    DISPLAY "Account ID     : " WS-CURR-ACCT-ID
    DISPLAY "Card Number    : " WS-XREF-CARD-NUM
    DISPLAY "Customer ID    : " WS-XREF-CUST-ID
    DISPLAY "Status         : " WS-CURR-ACCT-STATUS
    DISPLAY "Open Date      : " WS-CURR-OPEN-DATE
    DISPLAY "Expiry Date    : " WS-CURR-EXP-DATE
    DISPLAY "Reissue Date   : " WS-CURR-REISSUE-DATE
    DISPLAY "Group ID       : " WS-CURR-GROUP-ID
    IF CUSTOMER-FOUND
        DISPLAY "First Name     : " FUNCTION TRIM(WS-CURR-FIRST-NAME)
        DISPLAY "Middle Name    : " FUNCTION TRIM(WS-CURR-MIDDLE-NAME)
        DISPLAY "Last Name      : " FUNCTION TRIM(WS-CURR-LAST-NAME)
        DISPLAY "Address 1      : " FUNCTION TRIM(WS-CURR-ADDR-LINE-1)
        DISPLAY "Address 2      : " FUNCTION TRIM(WS-CURR-ADDR-LINE-2)
        DISPLAY "Address 3      : " FUNCTION TRIM(WS-CURR-ADDR-LINE-3)
        DISPLAY "State          : " WS-CURR-STATE
        DISPLAY "Country        : " WS-CURR-COUNTRY
        DISPLAY "ZIP            : " WS-CURR-ZIP
        DISPLAY "Phone 1        : " FUNCTION TRIM(WS-CURR-PHONE-1)
        DISPLAY "Phone 2        : " FUNCTION TRIM(WS-CURR-PHONE-2)
    END-IF
    DISPLAY "Enter new values. Leave blank to keep the current value.".

PROMPT-FOR-UPDATES.
    SET ACCOUNT-UNCHANGED TO TRUE
    SET CUSTOMER-UNCHANGED TO TRUE

    PERFORM PROMPT-ACCOUNT-STATUS
    PERFORM PROMPT-OPEN-DATE
    PERFORM PROMPT-EXPIRY-DATE
    PERFORM PROMPT-REISSUE-DATE
    PERFORM PROMPT-GROUP-ID

    IF CUSTOMER-FOUND
        PERFORM PROMPT-CUSTOMER-FIELDS
    END-IF.

PROMPT-ACCOUNT-STATUS.
    DISPLAY "Status (Y/N): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-INPUT-BUFFER)) TO WS-WORK-NAME
        IF WS-WORK-NAME(1:1) = "Y" OR WS-WORK-NAME(1:1) = "N"
            MOVE WS-WORK-NAME(1:1) TO WS-ACCOUNT-LINE(WS-ACCOUNT-IDX)(12:1)
            SET ACCOUNT-CHANGED TO TRUE
        ELSE
            DISPLAY "Ignoring invalid status."
        END-IF
    END-IF.

PROMPT-OPEN-DATE.
    DISPLAY "Open Date (YYYY-MM-DD): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-DATE
        IF FUNCTION LENGTH(FUNCTION TRIM(WS-INPUT-BUFFER)) = 10
            AND WS-WORK-DATE(5:1) = "-"
            AND WS-WORK-DATE(8:1) = "-"
            MOVE WS-WORK-DATE TO WS-ACCOUNT-LINE(WS-ACCOUNT-IDX)(49:10)
            SET ACCOUNT-CHANGED TO TRUE
        ELSE
            DISPLAY "Ignoring invalid date."
        END-IF
    END-IF.

PROMPT-EXPIRY-DATE.
    DISPLAY "Expiry Date (YYYY-MM-DD): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-DATE
        IF FUNCTION LENGTH(FUNCTION TRIM(WS-INPUT-BUFFER)) = 10
            AND WS-WORK-DATE(5:1) = "-"
            AND WS-WORK-DATE(8:1) = "-"
            MOVE WS-WORK-DATE TO WS-ACCOUNT-LINE(WS-ACCOUNT-IDX)(59:10)
            SET ACCOUNT-CHANGED TO TRUE
        ELSE
            DISPLAY "Ignoring invalid date."
        END-IF
    END-IF.

PROMPT-REISSUE-DATE.
    DISPLAY "Reissue Date (YYYY-MM-DD): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-DATE
        IF FUNCTION LENGTH(FUNCTION TRIM(WS-INPUT-BUFFER)) = 10
            AND WS-WORK-DATE(5:1) = "-"
            AND WS-WORK-DATE(8:1) = "-"
            MOVE WS-WORK-DATE TO WS-ACCOUNT-LINE(WS-ACCOUNT-IDX)(69:10)
            SET ACCOUNT-CHANGED TO TRUE
        ELSE
            DISPLAY "Ignoring invalid date."
        END-IF
    END-IF.

PROMPT-GROUP-ID.
    DISPLAY "Group ID (10 chars): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:10) TO WS-ACCOUNT-LINE(WS-ACCOUNT-IDX)(113:10)
        SET ACCOUNT-CHANGED TO TRUE
    END-IF.

PROMPT-CUSTOMER-FIELDS.
    PERFORM PROMPT-FIRST-NAME
    PERFORM PROMPT-MIDDLE-NAME
    PERFORM PROMPT-LAST-NAME
    PERFORM PROMPT-ADDR1
    PERFORM PROMPT-ADDR2
    PERFORM PROMPT-ADDR3
    PERFORM PROMPT-STATE
    PERFORM PROMPT-COUNTRY
    PERFORM PROMPT-ZIP
    PERFORM PROMPT-PHONE1
    PERFORM PROMPT-PHONE2.

PROMPT-FIRST-NAME.
    DISPLAY "First Name (25): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:25) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(10:25)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-MIDDLE-NAME.
    DISPLAY "Middle Name (25): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:25) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(35:25)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-LAST-NAME.
    DISPLAY "Last Name (25): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:25) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(60:25)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-ADDR1.
    DISPLAY "Address 1 (50): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:50) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(85:50)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-ADDR2.
    DISPLAY "Address 2 (50): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:50) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(135:50)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-ADDR3.
    DISPLAY "Address 3 (50): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:50) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(185:50)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-STATE.
    DISPLAY "State (2): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-INPUT-BUFFER)) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:2) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(235:2)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-COUNTRY.
    DISPLAY "Country (3): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-INPUT-BUFFER)) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:3) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(237:3)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-ZIP.
    DISPLAY "ZIP (10): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:10) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(240:10)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-PHONE1.
    DISPLAY "Phone 1 (15): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:15) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(250:15)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

PROMPT-PHONE2.
    DISPLAY "Phone 2 (15): " WITH NO ADVANCING
    ACCEPT WS-INPUT-BUFFER
    IF FUNCTION TRIM(WS-INPUT-BUFFER) NOT = SPACES
        MOVE SPACES TO WS-WORK-NAME
        MOVE FUNCTION TRIM(WS-INPUT-BUFFER) TO WS-WORK-NAME
        MOVE WS-WORK-NAME(1:15) TO WS-CUSTOMER-LINE(WS-CUSTOMER-IDX)(265:15)
        SET CUSTOMER-CHANGED TO TRUE
    END-IF.

SAVE-CHANGES.
    IF ACCOUNT-CHANGED
        OPEN OUTPUT ACCOUNT-FILE
        IF WS-ACCOUNT-STATUS NOT = "00"
            DISPLAY "Unable to rewrite account file. Status: " WS-ACCOUNT-STATUS
            STOP RUN
        END-IF
        PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-ACCOUNT-COUNT
            WRITE ACCOUNT-RAW-RECORD FROM WS-ACCOUNT-LINE(WS-IDX)
        END-PERFORM
        CLOSE ACCOUNT-FILE
    END-IF

    IF CUSTOMER-CHANGED
        OPEN OUTPUT CUSTOMER-FILE
        IF WS-CUSTOMER-STATUS NOT = "00"
            DISPLAY "Unable to rewrite customer file. Status: " WS-CUSTOMER-STATUS
            STOP RUN
        END-IF
        PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-CUSTOMER-COUNT
            WRITE CUSTOMER-RAW-RECORD FROM WS-CUSTOMER-LINE(WS-IDX)
        END-PERFORM
        CLOSE CUSTOMER-FILE
    END-IF.
