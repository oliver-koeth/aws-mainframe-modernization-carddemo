>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. COTRN02C.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT TRANSACTION-FILE ASSIGN TO DYNAMIC WS-TRANSACTION-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-TRANSACTION-STATUS.
    SELECT XREF-FILE ASSIGN TO DYNAMIC WS-XREF-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-XREF-STATUS.
    SELECT ACCOUNT-FILE ASSIGN TO DYNAMIC WS-ACCOUNT-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-ACCOUNT-STATUS.

DATA DIVISION.
FILE SECTION.
FD TRANSACTION-FILE.
01 TRANSACTION-RAW-RECORD            PIC X(350).

FD XREF-FILE.
01 XREF-RAW-RECORD                   PIC X(50).

FD ACCOUNT-FILE.
01 ACCOUNT-RAW-RECORD                PIC X(300).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-TRANSACTION-PATH            PIC X(256) VALUE SPACES.
   05 WS-XREF-PATH                   PIC X(256) VALUE SPACES.
   05 WS-ACCOUNT-PATH                PIC X(256) VALUE SPACES.
   05 WS-TRANSACTION-STATUS          PIC X(02) VALUE SPACES.
   05 WS-XREF-STATUS                 PIC X(02) VALUE SPACES.
   05 WS-ACCOUNT-STATUS              PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-END-OF-FILE                 PIC X VALUE "N".
      88 END-OF-FILE                             VALUE "Y".
      88 MORE-RECORDS                            VALUE "N".
   05 WS-XREF-FOUND                  PIC X VALUE "N".
      88 XREF-FOUND                              VALUE "Y".
      88 XREF-NOT-FOUND                          VALUE "N".
   05 WS-ACCOUNT-FOUND               PIC X VALUE "N".
      88 ACCOUNT-FOUND                           VALUE "Y".
      88 ACCOUNT-NOT-FOUND                       VALUE "N".
   05 WS-VALID                       PIC X VALUE "Y".
      88 INPUT-VALID                             VALUE "Y".
      88 INPUT-INVALID                           VALUE "N".

01 WS-SEARCH.
   05 WS-SEARCH-ACCOUNT-ID           PIC X(11) VALUE SPACES.
   05 WS-SEARCH-CARD-NUM             PIC X(16) VALUE SPACES.

01 WS-XREF-DATA.
   05 WS-XREF-CARD-NUM               PIC X(16) VALUE SPACES.
   05 WS-XREF-CUST-ID                PIC X(09) VALUE SPACES.
   05 WS-XREF-ACCT-ID                PIC X(11) VALUE SPACES.

01 WS-ACCOUNT-DATA.
   05 WS-ACCOUNT-LINE                PIC X(300) VALUE SPACES.
   05 WS-ACCOUNT-STATUS-CODE         PIC X(01) VALUE SPACE.
   05 WS-ACCOUNT-EXPIRY              PIC X(10) VALUE SPACES.

01 WS-INPUTS.
   05 WS-TYPE-CODE                   PIC X(10) VALUE SPACES.
   05 WS-CATEGORY-CODE               PIC X(10) VALUE SPACES.
   05 WS-SOURCE                      PIC X(20) VALUE SPACES.
   05 WS-AMOUNT-TEXT                 PIC X(20) VALUE SPACES.
   05 WS-DESCRIPTION                 PIC X(120) VALUE SPACES.
   05 WS-ORIG-DATE                   PIC X(20) VALUE SPACES.
   05 WS-PROC-DATE                   PIC X(20) VALUE SPACES.
   05 WS-MERCHANT-ID                 PIC X(20) VALUE SPACES.
   05 WS-MERCHANT-NAME               PIC X(80) VALUE SPACES.
   05 WS-MERCHANT-CITY               PIC X(80) VALUE SPACES.
   05 WS-MERCHANT-ZIP                PIC X(20) VALUE SPACES.
   05 WS-CONFIRM                     PIC X(10) VALUE SPACES.

01 WS-WORK.
   05 WS-MESSAGE                     PIC X(120) VALUE SPACES.
   05 WS-NEXT-TRAN-ID-N              PIC 9(16) VALUE 0.
   05 WS-LAST-TRAN-ID-N              PIC 9(16) VALUE 0.
   05 WS-AMOUNT-VALUE                PIC S9(9)V99 VALUE 0.
   05 WS-AMOUNT-ABS                  PIC 9(11) VALUE 0.
   05 WS-AMOUNT-ABS-TEXT             PIC 9(11) VALUE 0.
   05 WS-AMOUNT-TEXT-11 REDEFINES WS-AMOUNT-ABS-TEXT PIC X(11).
   05 WS-AMOUNT-LAST-DIGIT           PIC X(01) VALUE SPACE.
   05 WS-YEAR-N                      PIC 9(04) VALUE 0.
   05 WS-MONTH-N                     PIC 9(02) VALUE 0.
   05 WS-DAY-N                       PIC 9(02) VALUE 0.
   05 WS-DATE-CHECK                  PIC X(10) VALUE SPACES.
   05 WS-NEW-RECORD                  PIC X(350) VALUE SPACES.
   05 WS-NEW-TRAN-ID                 PIC X(16) VALUE SPACES.
   05 WS-TIMESTAMP-TAIL              PIC X(16) VALUE " 00:00:00.000000".

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATHS
    PERFORM PROMPT-FOR-KEYS
    PERFORM RESOLVE-ACCOUNT-AND-CARD
    IF INPUT-INVALID
        DISPLAY WS-MESSAGE
        GOBACK
    END-IF
    PERFORM PROMPT-FOR-DATA
    PERFORM VALIDATE-DATA
    IF INPUT-INVALID
        DISPLAY WS-MESSAGE
        GOBACK
    END-IF
    PERFORM CONFIRM-ADD
    IF FUNCTION UPPER-CASE(FUNCTION TRIM(WS-CONFIRM))(1:1) NOT = "Y"
        DISPLAY "Transaction add cancelled."
        GOBACK
    END-IF
    PERFORM ASSIGN-NEXT-TRANSACTION-ID
    PERFORM BUILD-TRANSACTION-RECORD
    PERFORM APPEND-TRANSACTION
    DISPLAY "Transaction added successfully. Tran ID: " WS-NEW-TRAN-ID
    GOBACK.

INITIALIZE-PATHS.
    ACCEPT WS-TRANSACTION-PATH FROM ENVIRONMENT "CARDDEMO_TRAN_PATH"
    IF WS-TRANSACTION-PATH = SPACES
        MOVE "app/data/ASCII/dailytran.txt" TO WS-TRANSACTION-PATH
    END-IF
    ACCEPT WS-XREF-PATH FROM ENVIRONMENT "CARDDEMO_XREF_PATH"
    IF WS-XREF-PATH = SPACES
        MOVE "app/data/ASCII/cardxref.txt" TO WS-XREF-PATH
    END-IF
    ACCEPT WS-ACCOUNT-PATH FROM ENVIRONMENT "CARDDEMO_ACCT_PATH"
    IF WS-ACCOUNT-PATH = SPACES
        MOVE "app/data/ASCII/acctdata.txt" TO WS-ACCOUNT-PATH
    END-IF.

PROMPT-FOR-KEYS.
    DISPLAY SPACE
    DISPLAY "Transaction Add"
    DISPLAY "Enter account ID or card number."
    DISPLAY "Account ID (11 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-ACCOUNT-ID
    DISPLAY "Card Number (16 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-CARD-NUM.

RESOLVE-ACCOUNT-AND-CARD.
    SET INPUT-VALID TO TRUE
    MOVE SPACES TO WS-MESSAGE
    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
        AND FUNCTION TRIM(WS-SEARCH-CARD-NUM) = SPACES
        SET INPUT-INVALID TO TRUE
        MOVE "Account or card number must be entered." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) NOT = SPACES
        IF FUNCTION TEST-NUMVAL(FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID)) NOT = 0
            SET INPUT-INVALID TO TRUE
            MOVE "Account ID must be numeric." TO WS-MESSAGE
            EXIT PARAGRAPH
        END-IF
    END-IF
    IF FUNCTION TRIM(WS-SEARCH-CARD-NUM) NOT = SPACES
        IF FUNCTION TEST-NUMVAL(FUNCTION TRIM(WS-SEARCH-CARD-NUM)) NOT = 0
            SET INPUT-INVALID TO TRUE
            MOVE "Card number must be numeric." TO WS-MESSAGE
            EXIT PARAGRAPH
        END-IF
    END-IF

    IF FUNCTION TRIM(WS-SEARCH-CARD-NUM) NOT = SPACES
        PERFORM FIND-XREF-BY-CARD
    ELSE
        PERFORM FIND-XREF-BY-ACCOUNT
    END-IF
    IF XREF-NOT-FOUND
        SET INPUT-INVALID TO TRUE
        IF FUNCTION TRIM(WS-SEARCH-CARD-NUM) NOT = SPACES
            MOVE "Card number not found in xref file." TO WS-MESSAGE
        ELSE
            MOVE "Account ID not found in xref file." TO WS-MESSAGE
        END-IF
        EXIT PARAGRAPH
    END-IF

    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) NOT = SPACES
        AND WS-SEARCH-ACCOUNT-ID NOT = WS-XREF-ACCT-ID
        SET INPUT-INVALID TO TRUE
        MOVE "Account ID does not match the supplied card number." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-SEARCH-CARD-NUM) NOT = SPACES
        AND WS-SEARCH-CARD-NUM NOT = WS-XREF-CARD-NUM
        SET INPUT-INVALID TO TRUE
        MOVE "Card number does not match the supplied account ID." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF

    MOVE WS-XREF-ACCT-ID TO WS-SEARCH-ACCOUNT-ID
    MOVE WS-XREF-CARD-NUM TO WS-SEARCH-CARD-NUM
    PERFORM FIND-ACCOUNT
    IF ACCOUNT-NOT-FOUND
        SET INPUT-INVALID TO TRUE
        MOVE "Account record not found." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF WS-ACCOUNT-STATUS-CODE NOT = "Y"
        SET INPUT-INVALID TO TRUE
        MOVE "Account is not active." TO WS-MESSAGE
    END-IF.

FIND-XREF-BY-CARD.
    SET XREF-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        SET INPUT-INVALID TO TRUE
        MOVE "Unable to open xref file." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(1:16) = WS-SEARCH-CARD-NUM
                    MOVE XREF-RAW-RECORD(1:16) TO WS-XREF-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-XREF-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-XREF-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

FIND-XREF-BY-ACCOUNT.
    SET XREF-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        SET INPUT-INVALID TO TRUE
        MOVE "Unable to open xref file." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(26:11) = WS-SEARCH-ACCOUNT-ID
                    MOVE XREF-RAW-RECORD(1:16) TO WS-XREF-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-XREF-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-XREF-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

FIND-ACCOUNT.
    SET ACCOUNT-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT ACCOUNT-FILE
    IF WS-ACCOUNT-STATUS NOT = "00"
        SET INPUT-INVALID TO TRUE
        MOVE "Unable to open account file." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    PERFORM UNTIL END-OF-FILE OR ACCOUNT-FOUND
        READ ACCOUNT-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF ACCOUNT-RAW-RECORD(1:11) = WS-SEARCH-ACCOUNT-ID
                    MOVE ACCOUNT-RAW-RECORD TO WS-ACCOUNT-LINE
                    MOVE ACCOUNT-RAW-RECORD(12:1) TO WS-ACCOUNT-STATUS-CODE
                    MOVE ACCOUNT-RAW-RECORD(59:10) TO WS-ACCOUNT-EXPIRY
                    SET ACCOUNT-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE ACCOUNT-FILE.

PROMPT-FOR-DATA.
    DISPLAY SPACE
    DISPLAY "Resolved Account ID : " WS-SEARCH-ACCOUNT-ID
    DISPLAY "Resolved Card Number: " WS-SEARCH-CARD-NUM
    DISPLAY "Type Code (2 digits): " WITH NO ADVANCING
    ACCEPT WS-TYPE-CODE
    DISPLAY "Category Code (4 digits): " WITH NO ADVANCING
    ACCEPT WS-CATEGORY-CODE
    DISPLAY "Source: " WITH NO ADVANCING
    ACCEPT WS-SOURCE
    DISPLAY "Amount (+99999999.99 or -99999999.99): " WITH NO ADVANCING
    ACCEPT WS-AMOUNT-TEXT
    DISPLAY "Description: " WITH NO ADVANCING
    ACCEPT WS-DESCRIPTION
    DISPLAY "Original Date (YYYY-MM-DD): " WITH NO ADVANCING
    ACCEPT WS-ORIG-DATE
    DISPLAY "Processed Date (YYYY-MM-DD, optional): " WITH NO ADVANCING
    ACCEPT WS-PROC-DATE
    DISPLAY "Merchant ID: " WITH NO ADVANCING
    ACCEPT WS-MERCHANT-ID
    DISPLAY "Merchant Name: " WITH NO ADVANCING
    ACCEPT WS-MERCHANT-NAME
    DISPLAY "Merchant City: " WITH NO ADVANCING
    ACCEPT WS-MERCHANT-CITY
    DISPLAY "Merchant ZIP: " WITH NO ADVANCING
    ACCEPT WS-MERCHANT-ZIP.

VALIDATE-DATA.
    SET INPUT-VALID TO TRUE
    MOVE SPACES TO WS-MESSAGE
    IF FUNCTION TRIM(WS-TYPE-CODE) = SPACES
        OR FUNCTION LENGTH(FUNCTION TRIM(WS-TYPE-CODE)) NOT = 2
        OR FUNCTION TEST-NUMVAL(FUNCTION TRIM(WS-TYPE-CODE)) NOT = 0
        SET INPUT-INVALID TO TRUE
        MOVE "Type code must be a 2-digit numeric value." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-CATEGORY-CODE) = SPACES
        OR FUNCTION LENGTH(FUNCTION TRIM(WS-CATEGORY-CODE)) NOT = 4
        OR FUNCTION TEST-NUMVAL(FUNCTION TRIM(WS-CATEGORY-CODE)) NOT = 0
        SET INPUT-INVALID TO TRUE
        MOVE "Category code must be a 4-digit numeric value." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-SOURCE) = SPACES
        SET INPUT-INVALID TO TRUE
        MOVE "Source cannot be empty." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-DESCRIPTION) = SPACES
        SET INPUT-INVALID TO TRUE
        MOVE "Description cannot be empty." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-AMOUNT-TEXT) = SPACES
        SET INPUT-INVALID TO TRUE
        MOVE "Amount cannot be empty." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF WS-AMOUNT-TEXT(1:1) NOT = "+" AND WS-AMOUNT-TEXT(1:1) NOT = "-"
        SET INPUT-INVALID TO TRUE
        MOVE "Amount must start with + or -." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TEST-NUMVAL-C(FUNCTION TRIM(WS-AMOUNT-TEXT)) NOT = 0
        SET INPUT-INVALID TO TRUE
        MOVE "Amount should be in format -99999999.99." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    COMPUTE WS-AMOUNT-VALUE = FUNCTION NUMVAL-C(FUNCTION TRIM(WS-AMOUNT-TEXT))
    MOVE WS-ORIG-DATE TO WS-DATE-CHECK
    PERFORM VALIDATE-DATE
    IF INPUT-INVALID
        MOVE "Original date should be in format YYYY-MM-DD." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-PROC-DATE) = SPACES
        MOVE WS-ORIG-DATE TO WS-PROC-DATE
    END-IF
    MOVE WS-PROC-DATE TO WS-DATE-CHECK
    PERFORM VALIDATE-DATE
    IF INPUT-INVALID
        MOVE "Processed date should be in format YYYY-MM-DD." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-MERCHANT-ID) = SPACES
        OR FUNCTION TEST-NUMVAL(FUNCTION TRIM(WS-MERCHANT-ID)) NOT = 0
        SET INPUT-INVALID TO TRUE
        MOVE "Merchant ID must be numeric." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-MERCHANT-NAME) = SPACES
        SET INPUT-INVALID TO TRUE
        MOVE "Merchant name cannot be empty." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-MERCHANT-CITY) = SPACES
        SET INPUT-INVALID TO TRUE
        MOVE "Merchant city cannot be empty." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-MERCHANT-ZIP) = SPACES
        SET INPUT-INVALID TO TRUE
        MOVE "Merchant ZIP cannot be empty." TO WS-MESSAGE
        EXIT PARAGRAPH
    END-IF
    IF WS-ORIG-DATE > WS-ACCOUNT-EXPIRY
        SET INPUT-INVALID TO TRUE
        MOVE "Transaction received after account expiration." TO WS-MESSAGE
    END-IF.

VALIDATE-DATE.
    IF FUNCTION TRIM(WS-DATE-CHECK) = SPACES
        SET INPUT-INVALID TO TRUE
        EXIT PARAGRAPH
    END-IF
    IF WS-DATE-CHECK(1:4) IS NOT NUMERIC
        OR WS-DATE-CHECK(5:1) NOT = "-"
        OR WS-DATE-CHECK(6:2) IS NOT NUMERIC
        OR WS-DATE-CHECK(8:1) NOT = "-"
        OR WS-DATE-CHECK(9:2) IS NOT NUMERIC
        SET INPUT-INVALID TO TRUE
        EXIT PARAGRAPH
    END-IF
    COMPUTE WS-YEAR-N = FUNCTION NUMVAL(WS-DATE-CHECK(1:4))
    COMPUTE WS-MONTH-N = FUNCTION NUMVAL(WS-DATE-CHECK(6:2))
    COMPUTE WS-DAY-N = FUNCTION NUMVAL(WS-DATE-CHECK(9:2))
    IF WS-MONTH-N < 1 OR WS-MONTH-N > 12 OR WS-DAY-N < 1 OR WS-DAY-N > 31
        SET INPUT-INVALID TO TRUE
    END-IF.

CONFIRM-ADD.
    DISPLAY "Confirm add (Y/N): " WITH NO ADVANCING
    ACCEPT WS-CONFIRM.

ASSIGN-NEXT-TRANSACTION-ID.
    MOVE 0 TO WS-LAST-TRAN-ID-N
    SET MORE-RECORDS TO TRUE
    OPEN INPUT TRANSACTION-FILE
    IF WS-TRANSACTION-STATUS NOT = "00"
        DISPLAY "Unable to open transaction file. Status: " WS-TRANSACTION-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ TRANSACTION-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF TRANSACTION-RAW-RECORD(1:16) IS NUMERIC
                    COMPUTE WS-LAST-TRAN-ID-N =
                        FUNCTION NUMVAL(TRANSACTION-RAW-RECORD(1:16))
                END-IF
        END-READ
    END-PERFORM
    CLOSE TRANSACTION-FILE
    ADD 1 TO WS-LAST-TRAN-ID-N
    MOVE WS-LAST-TRAN-ID-N TO WS-NEW-TRAN-ID
    MOVE WS-LAST-TRAN-ID-N TO WS-NEXT-TRAN-ID-N.

BUILD-TRANSACTION-RECORD.
    MOVE ALL " " TO WS-NEW-RECORD
    MOVE WS-NEW-TRAN-ID TO WS-NEW-RECORD(1:16)
    MOVE FUNCTION TRIM(WS-TYPE-CODE) TO WS-NEW-RECORD(17:2)
    MOVE FUNCTION TRIM(WS-CATEGORY-CODE) TO WS-NEW-RECORD(19:4)
    MOVE FUNCTION TRIM(WS-SOURCE) TO WS-NEW-RECORD(23:10)
    MOVE FUNCTION TRIM(WS-DESCRIPTION) TO WS-NEW-RECORD(33:100)
    PERFORM ENCODE-AMOUNT
    MOVE WS-AMOUNT-TEXT-11 TO WS-NEW-RECORD(133:11)
    MOVE FUNCTION TRIM(WS-MERCHANT-ID) TO WS-NEW-RECORD(144:9)
    MOVE FUNCTION TRIM(WS-MERCHANT-NAME) TO WS-NEW-RECORD(153:50)
    MOVE FUNCTION TRIM(WS-MERCHANT-CITY) TO WS-NEW-RECORD(203:50)
    MOVE FUNCTION TRIM(WS-MERCHANT-ZIP) TO WS-NEW-RECORD(253:10)
    MOVE WS-SEARCH-CARD-NUM TO WS-NEW-RECORD(263:16)
    STRING FUNCTION TRIM(WS-ORIG-DATE) WS-TIMESTAMP-TAIL
        DELIMITED BY SIZE INTO WS-NEW-RECORD(279:26)
    STRING FUNCTION TRIM(WS-PROC-DATE) WS-TIMESTAMP-TAIL
        DELIMITED BY SIZE INTO WS-NEW-RECORD(305:26).

ENCODE-AMOUNT.
    COMPUTE WS-AMOUNT-ABS = FUNCTION ABS(WS-AMOUNT-VALUE * 100)
    MOVE WS-AMOUNT-ABS TO WS-AMOUNT-ABS-TEXT
    MOVE WS-AMOUNT-TEXT-11(11:1) TO WS-AMOUNT-LAST-DIGIT
    IF WS-AMOUNT-VALUE < 0
        EVALUATE WS-AMOUNT-LAST-DIGIT
            WHEN "0" MOVE "}" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "1" MOVE "J" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "2" MOVE "K" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "3" MOVE "L" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "4" MOVE "M" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "5" MOVE "N" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "6" MOVE "O" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "7" MOVE "P" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "8" MOVE "Q" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "9" MOVE "R" TO WS-AMOUNT-TEXT-11(11:1)
        END-EVALUATE
    ELSE
        EVALUATE WS-AMOUNT-LAST-DIGIT
            WHEN "0" MOVE "{" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "1" MOVE "A" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "2" MOVE "B" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "3" MOVE "C" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "4" MOVE "D" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "5" MOVE "E" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "6" MOVE "F" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "7" MOVE "G" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "8" MOVE "H" TO WS-AMOUNT-TEXT-11(11:1)
            WHEN "9" MOVE "I" TO WS-AMOUNT-TEXT-11(11:1)
        END-EVALUATE
    END-IF.

APPEND-TRANSACTION.
    OPEN EXTEND TRANSACTION-FILE
    IF WS-TRANSACTION-STATUS NOT = "00"
        DISPLAY "Unable to append transaction file. Status: " WS-TRANSACTION-STATUS
        GOBACK
    END-IF
    MOVE WS-NEW-RECORD TO TRANSACTION-RAW-RECORD
    WRITE TRANSACTION-RAW-RECORD
    CLOSE TRANSACTION-FILE.
