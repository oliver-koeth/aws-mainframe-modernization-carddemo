>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. GCUSRSEC.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT USRSEC-FILE ASSIGN TO DYNAMIC WS-USRSEC-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-USRSEC-STATUS.

DATA DIVISION.
FILE SECTION.
FD USRSEC-FILE.
01 USRSEC-RECORD PIC X(80).

WORKING-STORAGE SECTION.
01 WS-FILE-CONTROL.
   05 WS-USRSEC-PATH       PIC X(256) VALUE SPACES.
   05 WS-USRSEC-STATUS     PIC X(02) VALUE SPACES.
   05 WS-EOF               PIC X VALUE "N".
      88 END-OF-USRSEC                VALUE "Y".
      88 MORE-USRSEC                  VALUE "N".
   05 WS-FOUND             PIC X VALUE "N".
      88 USER-FOUND                   VALUE "Y".
      88 USER-NOT-FOUND               VALUE "N".
   05 WS-EXIT              PIC X VALUE "N".
      88 SECURITY-DONE                VALUE "Y".
      88 SECURITY-ACTIVE              VALUE "N".
   05 WS-MODIFIED          PIC X VALUE "N".
      88 USERS-MODIFIED               VALUE "Y".
      88 USERS-UNCHANGED              VALUE "N".

01 WS-INPUTS.
   05 WS-CHOICE            PIC X VALUE SPACE.
   05 WS-EFFECTIVE-MODE    PIC X VALUE SPACE.
   05 WS-SEARCH-ID         PIC X(08) VALUE SPACES.
   05 WS-FIRST-NAME        PIC X(20) VALUE SPACES.
   05 WS-LAST-NAME         PIC X(20) VALUE SPACES.
   05 WS-PASSWORD          PIC X(08) VALUE SPACES.
   05 WS-USER-TYPE         PIC X(01) VALUE SPACES.
   05 WS-MESSAGE           PIC X(80) VALUE SPACES.

01 WS-TABLE-CONTROL.
   05 WS-USER-COUNT        PIC 9(04) VALUE 0.
   05 WS-IDX               PIC 9(04) VALUE 0.
   05 WS-TARGET-IDX        PIC 9(04) VALUE 0.

01 WS-USERS.
   05 WS-USER-ENTRY OCCURS 200 TIMES.
      10 WS-USR-ID         PIC X(08).
      10 WS-USR-FNAME      PIC X(20).
      10 WS-USR-LNAME      PIC X(20).
      10 WS-USR-PWD        PIC X(08).
      10 WS-USR-TYPE       PIC X(01).
      10 WS-USR-FILLER     PIC X(23).

01 SEC-USER-DATA.
   05 SEC-USR-ID           PIC X(08).
   05 SEC-USR-FNAME        PIC X(20).
   05 SEC-USR-LNAME        PIC X(20).
   05 SEC-USR-PWD          PIC X(08).
   05 SEC-USR-TYPE         PIC X(01).
   05 SEC-USR-FILLER       PIC X(23).

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
         88 CDEMO-PGM-ENTER            VALUE 0.
         88 CDEMO-PGM-REENTER          VALUE 1.
   05 CDEMO-CUSTOMER-INFO.
      10 CDEMO-CUST-ID                 PIC 9(09).
      10 CDEMO-CUST-FNAME              PIC X(25).
      10 CDEMO-CUST-MNAME              PIC X(25).
      10 CDEMO-CUST-LNAME              PIC X(25).
   05 CDEMO-ACCOUNT-INFO.
      10 CDEMO-ACCT-ID                 PIC 9(11).
      10 CDEMO-ACCT-STATUS             PIC X(01).
   05 CDEMO-CARD-INFO.
      10 CDEMO-CARD-NUM                PIC 9(16).
   05 CDEMO-MORE-INFO.
      10 CDEMO-LAST-MAP                PIC X(07).
      10 CDEMO-LAST-MAPSET             PIC X(07).
01 LK-MODE                             PIC X.

PROCEDURE DIVISION USING CARDDEMO-COMMAREA LK-MODE.
MAIN-PARA.
    PERFORM INITIALIZE-USRSEC-PATH
    PERFORM ENSURE-USRSEC-FILE
    MOVE FUNCTION UPPER-CASE(LK-MODE) TO WS-EFFECTIVE-MODE

    EVALUATE WS-EFFECTIVE-MODE
        WHEN "L"
            PERFORM LIST-USERS
            GOBACK
        WHEN "A"
            PERFORM ADD-USER
            GOBACK
        WHEN "U"
            PERFORM UPDATE-USER
            GOBACK
        WHEN "D"
            PERFORM DELETE-USER
            GOBACK
        WHEN OTHER
            CONTINUE
    END-EVALUATE

    SET SECURITY-ACTIVE TO TRUE

    PERFORM UNTIL SECURITY-DONE
        DISPLAY SPACE
        DISPLAY "User Security Maintenance"
        DISPLAY "1. List users"
        DISPLAY "2. Add user"
        DISPLAY "3. Update user"
        DISPLAY "4. Delete user"
        DISPLAY "0. Return"
        DISPLAY "Select option: " WITH NO ADVANCING
        ACCEPT WS-CHOICE

        EVALUATE WS-CHOICE
            WHEN "1"
                PERFORM LIST-USERS
            WHEN "2"
                PERFORM ADD-USER
            WHEN "3"
                PERFORM UPDATE-USER
            WHEN "4"
                PERFORM DELETE-USER
            WHEN "0"
                SET SECURITY-DONE TO TRUE
            WHEN OTHER
                DISPLAY "Invalid option."
        END-EVALUATE
    END-PERFORM

    GOBACK.

INITIALIZE-USRSEC-PATH.
    ACCEPT WS-USRSEC-PATH FROM ENVIRONMENT "CARDDEMO_USRSEC_PATH"
    IF WS-USRSEC-PATH = SPACES
        MOVE "app/data/ASCII/usrsec.dat" TO WS-USRSEC-PATH
    END-IF.

ENSURE-USRSEC-FILE.
    OPEN INPUT USRSEC-FILE
    EVALUATE WS-USRSEC-STATUS
        WHEN "00"
            CLOSE USRSEC-FILE
        WHEN "35"
            PERFORM WRITE-DEFAULT-USERS
        WHEN OTHER
            DISPLAY "Unable to open user security file. Status: "
                WS-USRSEC-STATUS
            STOP RUN
    END-EVALUATE.

WRITE-DEFAULT-USERS.
    OPEN OUTPUT USRSEC-FILE
    IF WS-USRSEC-STATUS NOT = "00"
        DISPLAY "Unable to create user security file. Status: "
            WS-USRSEC-STATUS
        STOP RUN
    END-IF

    INITIALIZE SEC-USER-DATA
    MOVE "ADMIN001" TO SEC-USR-ID
    MOVE "ADMIN" TO SEC-USR-FNAME
    MOVE "USER" TO SEC-USR-LNAME
    MOVE "PASSWORD" TO SEC-USR-PWD
    MOVE "A" TO SEC-USR-TYPE
    WRITE USRSEC-RECORD FROM SEC-USER-DATA

    INITIALIZE SEC-USER-DATA
    MOVE "USER0001" TO SEC-USR-ID
    MOVE "CARD" TO SEC-USR-FNAME
    MOVE "USER" TO SEC-USR-LNAME
    MOVE "PASSWORD" TO SEC-USR-PWD
    MOVE "U" TO SEC-USR-TYPE
    WRITE USRSEC-RECORD FROM SEC-USER-DATA

    CLOSE USRSEC-FILE.

LOAD-USERS.
    MOVE 0 TO WS-USER-COUNT
    SET MORE-USRSEC TO TRUE
    OPEN INPUT USRSEC-FILE
    IF WS-USRSEC-STATUS NOT = "00"
        DISPLAY "Unable to read user security file. Status: "
            WS-USRSEC-STATUS
        STOP RUN
    END-IF

    PERFORM UNTIL END-OF-USRSEC
        READ USRSEC-FILE INTO SEC-USER-DATA
            AT END
                SET END-OF-USRSEC TO TRUE
            NOT AT END
                IF SEC-USR-ID NOT = SPACES
                    ADD 1 TO WS-USER-COUNT
                    MOVE SEC-USR-ID TO WS-USR-ID(WS-USER-COUNT)
                    MOVE SEC-USR-FNAME TO WS-USR-FNAME(WS-USER-COUNT)
                    MOVE SEC-USR-LNAME TO WS-USR-LNAME(WS-USER-COUNT)
                    MOVE SEC-USR-PWD TO WS-USR-PWD(WS-USER-COUNT)
                    MOVE SEC-USR-TYPE TO WS-USR-TYPE(WS-USER-COUNT)
                    MOVE SEC-USR-FILLER TO WS-USR-FILLER(WS-USER-COUNT)
                END-IF
        END-READ
    END-PERFORM

    CLOSE USRSEC-FILE.

SAVE-USERS.
    OPEN OUTPUT USRSEC-FILE
    IF WS-USRSEC-STATUS NOT = "00"
        DISPLAY "Unable to rewrite user security file. Status: "
            WS-USRSEC-STATUS
        STOP RUN
    END-IF

    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-USER-COUNT
        INITIALIZE SEC-USER-DATA
        MOVE WS-USR-ID(WS-IDX) TO SEC-USR-ID
        MOVE WS-USR-FNAME(WS-IDX) TO SEC-USR-FNAME
        MOVE WS-USR-LNAME(WS-IDX) TO SEC-USR-LNAME
        MOVE WS-USR-PWD(WS-IDX) TO SEC-USR-PWD
        MOVE WS-USR-TYPE(WS-IDX) TO SEC-USR-TYPE
        MOVE WS-USR-FILLER(WS-IDX) TO SEC-USR-FILLER
        WRITE USRSEC-RECORD FROM SEC-USER-DATA
    END-PERFORM

    CLOSE USRSEC-FILE.

FIND-USER.
    SET USER-NOT-FOUND TO TRUE
    MOVE 0 TO WS-TARGET-IDX
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-USER-COUNT
        IF WS-USR-ID(WS-IDX) = WS-SEARCH-ID
            MOVE WS-IDX TO WS-TARGET-IDX
            SET USER-FOUND TO TRUE
            EXIT PERFORM
        END-IF
    END-PERFORM.

PROMPT-USER-ID.
    DISPLAY "User ID (8 chars): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-ID
    MOVE FUNCTION UPPER-CASE(WS-SEARCH-ID) TO WS-SEARCH-ID.

PROMPT-NEW-USER-DATA.
    DISPLAY "First Name        : " WITH NO ADVANCING
    ACCEPT WS-FIRST-NAME
    DISPLAY "Last Name         : " WITH NO ADVANCING
    ACCEPT WS-LAST-NAME
    DISPLAY "Password (8 chars): " WITH NO ADVANCING
    ACCEPT WS-PASSWORD
    MOVE FUNCTION UPPER-CASE(WS-PASSWORD) TO WS-PASSWORD
    DISPLAY "User Type (A/U)   : " WITH NO ADVANCING
    ACCEPT WS-USER-TYPE
    MOVE FUNCTION UPPER-CASE(WS-USER-TYPE) TO WS-USER-TYPE.

VALIDATE-NEW-USER.
    MOVE SPACES TO WS-MESSAGE
    IF WS-SEARCH-ID = SPACES
        MOVE "User ID cannot be blank." TO WS-MESSAGE
    ELSE
        IF WS-FIRST-NAME = SPACES
            MOVE "First name cannot be blank." TO WS-MESSAGE
        ELSE
            IF WS-LAST-NAME = SPACES
                MOVE "Last name cannot be blank." TO WS-MESSAGE
            ELSE
                IF WS-PASSWORD = SPACES
                    MOVE "Password cannot be blank." TO WS-MESSAGE
                ELSE
                    IF WS-USER-TYPE NOT = "A"
                        AND WS-USER-TYPE NOT = "U"
                        MOVE "User type must be A or U." TO WS-MESSAGE
                    END-IF
                END-IF
            END-IF
        END-IF
    END-IF.

LIST-USERS.
    PERFORM LOAD-USERS
    DISPLAY SPACE
    DISPLAY "User ID   Name                           Type"
    DISPLAY "--------  -----------------------------  ----"
    IF WS-USER-COUNT = 0
        DISPLAY "No users found."
    ELSE
        PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-USER-COUNT
            DISPLAY WS-USR-ID(WS-IDX) "  "
                WS-USR-FNAME(WS-IDX) " "
                WS-USR-LNAME(WS-IDX) "  "
                WS-USR-TYPE(WS-IDX)
        END-PERFORM
    END-IF.

ADD-USER.
    PERFORM LOAD-USERS
    INITIALIZE WS-INPUTS
    PERFORM PROMPT-USER-ID
    PERFORM PROMPT-NEW-USER-DATA
    PERFORM VALIDATE-NEW-USER
    IF WS-MESSAGE NOT = SPACES
        DISPLAY WS-MESSAGE
        EXIT PARAGRAPH
    END-IF

    PERFORM FIND-USER
    IF USER-FOUND
        DISPLAY "User already exists."
        EXIT PARAGRAPH
    END-IF

    IF WS-USER-COUNT >= 200
        DISPLAY "User table limit reached."
        EXIT PARAGRAPH
    END-IF

    ADD 1 TO WS-USER-COUNT
    MOVE WS-SEARCH-ID TO WS-USR-ID(WS-USER-COUNT)
    MOVE WS-FIRST-NAME TO WS-USR-FNAME(WS-USER-COUNT)
    MOVE WS-LAST-NAME TO WS-USR-LNAME(WS-USER-COUNT)
    MOVE WS-PASSWORD TO WS-USR-PWD(WS-USER-COUNT)
    MOVE WS-USER-TYPE TO WS-USR-TYPE(WS-USER-COUNT)
    MOVE SPACES TO WS-USR-FILLER(WS-USER-COUNT)
    PERFORM SAVE-USERS
    DISPLAY "User added.".

UPDATE-USER.
    PERFORM LOAD-USERS
    INITIALIZE WS-INPUTS
    PERFORM PROMPT-USER-ID
    PERFORM FIND-USER
    IF USER-NOT-FOUND
        DISPLAY "User not found."
        EXIT PARAGRAPH
    END-IF

    DISPLAY "Current first name: " WS-USR-FNAME(WS-TARGET-IDX)
    DISPLAY "Current last name : " WS-USR-LNAME(WS-TARGET-IDX)
    DISPLAY "Current type      : " WS-USR-TYPE(WS-TARGET-IDX)
    PERFORM PROMPT-NEW-USER-DATA
    PERFORM VALIDATE-NEW-USER
    IF WS-MESSAGE NOT = SPACES
        DISPLAY WS-MESSAGE
        EXIT PARAGRAPH
    END-IF

    MOVE WS-FIRST-NAME TO WS-USR-FNAME(WS-TARGET-IDX)
    MOVE WS-LAST-NAME TO WS-USR-LNAME(WS-TARGET-IDX)
    MOVE WS-PASSWORD TO WS-USR-PWD(WS-TARGET-IDX)
    MOVE WS-USER-TYPE TO WS-USR-TYPE(WS-TARGET-IDX)
    PERFORM SAVE-USERS
    DISPLAY "User updated.".

DELETE-USER.
    PERFORM LOAD-USERS
    INITIALIZE WS-INPUTS
    PERFORM PROMPT-USER-ID
    PERFORM FIND-USER
    IF USER-NOT-FOUND
        DISPLAY "User not found."
        EXIT PARAGRAPH
    END-IF

    DISPLAY "Deleting " WS-USR-ID(WS-TARGET-IDX) " "
        WS-USR-FNAME(WS-TARGET-IDX) " " WS-USR-LNAME(WS-TARGET-IDX)

    PERFORM VARYING WS-IDX FROM WS-TARGET-IDX BY 1
        UNTIL WS-IDX >= WS-USER-COUNT
        MOVE WS-USR-ID(WS-IDX + 1) TO WS-USR-ID(WS-IDX)
        MOVE WS-USR-FNAME(WS-IDX + 1) TO WS-USR-FNAME(WS-IDX)
        MOVE WS-USR-LNAME(WS-IDX + 1) TO WS-USR-LNAME(WS-IDX)
        MOVE WS-USR-PWD(WS-IDX + 1) TO WS-USR-PWD(WS-IDX)
        MOVE WS-USR-TYPE(WS-IDX + 1) TO WS-USR-TYPE(WS-IDX)
        MOVE WS-USR-FILLER(WS-IDX + 1) TO WS-USR-FILLER(WS-IDX)
    END-PERFORM

    IF WS-USER-COUNT > 0
        INITIALIZE WS-USER-ENTRY(WS-USER-COUNT)
        SUBTRACT 1 FROM WS-USER-COUNT
    END-IF

    PERFORM SAVE-USERS
    DISPLAY "User deleted.".
