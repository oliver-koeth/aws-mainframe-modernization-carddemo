>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. COCRDUPC.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT CARD-FILE ASSIGN TO DYNAMIC WS-CARD-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-CARD-STATUS.
    SELECT XREF-FILE ASSIGN TO DYNAMIC WS-XREF-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-XREF-STATUS.

DATA DIVISION.
FILE SECTION.
FD CARD-FILE.
01 CARD-RAW-RECORD                  PIC X(150).

FD XREF-FILE.
01 XREF-RAW-RECORD                  PIC X(50).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-CARD-PATH                  PIC X(256) VALUE SPACES.
   05 WS-XREF-PATH                  PIC X(256) VALUE SPACES.
   05 WS-CARD-STATUS                PIC X(02) VALUE SPACES.
   05 WS-XREF-STATUS                PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-END-OF-FILE                PIC X VALUE "N".
      88 END-OF-FILE                            VALUE "Y".
      88 MORE-RECORDS                           VALUE "N".
   05 WS-CARD-FOUND                 PIC X VALUE "N".
      88 CARD-FOUND                             VALUE "Y".
      88 CARD-NOT-FOUND                         VALUE "N".
   05 WS-XREF-FOUND                 PIC X VALUE "N".
      88 XREF-FOUND                             VALUE "Y".
      88 XREF-NOT-FOUND                         VALUE "N".
   05 WS-CHANGED                    PIC X VALUE "N".
      88 CARD-CHANGED                           VALUE "Y".
      88 CARD-UNCHANGED                         VALUE "N".
   05 WS-VALID                      PIC X VALUE "Y".
      88 INPUT-VALID                            VALUE "Y".
      88 INPUT-INVALID                          VALUE "N".

01 WS-SEARCH.
   05 WS-SEARCH-ACCOUNT-ID          PIC X(11) VALUE SPACES.
   05 WS-SEARCH-CARD-NUM            PIC X(16) VALUE SPACES.

01 WS-IDENTIFIERS.
   05 WS-CURRENT-CARD-NUM           PIC X(16) VALUE SPACES.
   05 WS-CURRENT-ACCT-ID            PIC X(11) VALUE SPACES.
   05 WS-CURRENT-CUST-ID            PIC X(09) VALUE SPACES.
   05 WS-CARD-IDX                   PIC 9(04) VALUE 0.
   05 WS-CARD-COUNT                 PIC 9(04) VALUE 0.
   05 WS-IDX                        PIC 9(04) VALUE 0.

01 WS-CARDS.
   05 WS-CARD-ENTRY OCCURS 500 TIMES.
      10 WS-CARD-LINE               PIC X(150).

01 WS-CURRENT.
   05 WS-CURRENT-CVV                PIC X(03) VALUE SPACES.
   05 WS-CURRENT-NAME               PIC X(50) VALUE SPACES.
   05 WS-CURRENT-EXPIRY             PIC X(10) VALUE SPACES.
   05 WS-CURRENT-STATUS             PIC X(01) VALUE SPACES.

01 WS-UPDATES.
   05 WS-NAME-INPUT                 PIC X(80) VALUE SPACES.
   05 WS-MONTH-INPUT                PIC X(10) VALUE SPACES.
   05 WS-YEAR-INPUT                 PIC X(10) VALUE SPACES.
   05 WS-STATUS-INPUT               PIC X(10) VALUE SPACES.
   05 WS-WORK-MONTH                 PIC 9(02) VALUE 0.
   05 WS-WORK-YEAR                  PIC 9(04) VALUE 0.
   05 WS-NAME-LENGTH                PIC 9(03) VALUE 0.
   05 WS-CHAR-IDX                   PIC 9(03) VALUE 0.
   05 WS-TEST-CHAR                  PIC X(01) VALUE SPACE.
   05 WS-NEW-NAME                   PIC X(50) VALUE SPACES.
   05 WS-NEW-EXPIRY                 PIC X(10) VALUE SPACES.
   05 WS-NEW-STATUS                 PIC X(01) VALUE SPACES.

01 WS-MESSAGES.
   05 WS-MESSAGE                    PIC X(120) VALUE SPACES.

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATHS
    PERFORM LOAD-CARDS
    PERFORM PROMPT-FOR-LOOKUP
    PERFORM RESOLVE-CARD
    IF CARD-NOT-FOUND
        DISPLAY "Credit card update failed: card not found."
        GOBACK
    END-IF
    PERFORM EXTRACT-CARD-FIELDS
    PERFORM DISPLAY-CARD
    PERFORM PROMPT-FOR-UPDATES
    IF INPUT-INVALID
        DISPLAY WS-MESSAGE
        GOBACK
    END-IF
    IF CARD-UNCHANGED
        DISPLAY "No card changes were supplied."
        GOBACK
    END-IF
    PERFORM APPLY-UPDATES
    PERFORM SAVE-CARDS
    DISPLAY "Credit card update complete."
    GOBACK.

INITIALIZE-PATHS.
    ACCEPT WS-CARD-PATH FROM ENVIRONMENT "CARDDEMO_CARD_PATH"
    IF WS-CARD-PATH = SPACES
        MOVE "app/data/ASCII/carddata.txt" TO WS-CARD-PATH
    END-IF
    ACCEPT WS-XREF-PATH FROM ENVIRONMENT "CARDDEMO_XREF_PATH"
    IF WS-XREF-PATH = SPACES
        MOVE "app/data/ASCII/cardxref.txt" TO WS-XREF-PATH
    END-IF.

LOAD-CARDS.
    MOVE 0 TO WS-CARD-COUNT
    SET MORE-RECORDS TO TRUE
    OPEN INPUT CARD-FILE
    IF WS-CARD-STATUS NOT = "00"
        DISPLAY "Unable to open card file. Status: " WS-CARD-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ CARD-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                ADD 1 TO WS-CARD-COUNT
                MOVE CARD-RAW-RECORD TO WS-CARD-LINE(WS-CARD-COUNT)
        END-READ
    END-PERFORM
    CLOSE CARD-FILE.

PROMPT-FOR-LOOKUP.
    DISPLAY SPACE
    DISPLAY "Credit Card Update"
    DISPLAY "Lookup by account ID or card number."
    DISPLAY "Account ID (11 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-ACCOUNT-ID
    DISPLAY "Card Number (16 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-CARD-NUM.

RESOLVE-CARD.
    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
        AND FUNCTION TRIM(WS-SEARCH-CARD-NUM) = SPACES
        DISPLAY "You must enter an account ID or a card number."
        GOBACK
    END-IF

    SET XREF-NOT-FOUND TO TRUE
    IF FUNCTION TRIM(WS-SEARCH-CARD-NUM) NOT = SPACES
        PERFORM FIND-XREF-BY-CARD
        IF XREF-FOUND
            IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
                MOVE WS-CURRENT-ACCT-ID TO WS-SEARCH-ACCOUNT-ID
            ELSE
                IF WS-CURRENT-ACCT-ID NOT = WS-SEARCH-ACCOUNT-ID
                    DISPLAY "Supplied account ID does not match the card number."
                    GOBACK
                END-IF
            END-IF
        END-IF
    ELSE
        PERFORM FIND-XREF-BY-ACCOUNT
        IF XREF-FOUND
            MOVE WS-CURRENT-CARD-NUM TO WS-SEARCH-CARD-NUM
        END-IF
    END-IF

    SET CARD-NOT-FOUND TO TRUE
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-CARD-COUNT OR CARD-FOUND
        IF WS-CARD-LINE(WS-IDX)(1:16) = WS-SEARCH-CARD-NUM
            MOVE WS-IDX TO WS-CARD-IDX
            SET CARD-FOUND TO TRUE
        END-IF
    END-PERFORM.

FIND-XREF-BY-CARD.
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(1:16) = WS-SEARCH-CARD-NUM
                    MOVE XREF-RAW-RECORD(1:16) TO WS-CURRENT-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-CURRENT-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-CURRENT-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

FIND-XREF-BY-ACCOUNT.
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(26:11) = WS-SEARCH-ACCOUNT-ID
                    MOVE XREF-RAW-RECORD(1:16) TO WS-CURRENT-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-CURRENT-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-CURRENT-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

EXTRACT-CARD-FIELDS.
    IF WS-CURRENT-CARD-NUM = SPACES
        MOVE WS-CARD-LINE(WS-CARD-IDX)(1:16) TO WS-CURRENT-CARD-NUM
    END-IF
    IF WS-CURRENT-ACCT-ID = SPACES
        MOVE WS-CARD-LINE(WS-CARD-IDX)(17:11) TO WS-CURRENT-ACCT-ID
    END-IF
    MOVE WS-CARD-LINE(WS-CARD-IDX)(28:3) TO WS-CURRENT-CVV
    MOVE WS-CARD-LINE(WS-CARD-IDX)(31:50) TO WS-CURRENT-NAME
    MOVE WS-CARD-LINE(WS-CARD-IDX)(81:10) TO WS-CURRENT-EXPIRY
    MOVE WS-CARD-LINE(WS-CARD-IDX)(91:1) TO WS-CURRENT-STATUS.

DISPLAY-CARD.
    DISPLAY SPACE
    DISPLAY "Current Credit Card Details"
    DISPLAY "Card Number    : " WS-CURRENT-CARD-NUM
    DISPLAY "Account ID     : " WS-CURRENT-ACCT-ID
    IF WS-CURRENT-CUST-ID NOT = SPACES
        DISPLAY "Customer ID    : " WS-CURRENT-CUST-ID
    END-IF
    DISPLAY "CVV            : " WS-CURRENT-CVV
    DISPLAY "Embossed Name  : " FUNCTION TRIM(WS-CURRENT-NAME)
    DISPLAY "Expiry Date    : " WS-CURRENT-EXPIRY
    DISPLAY "Active Status  : " WS-CURRENT-STATUS.

PROMPT-FOR-UPDATES.
    SET INPUT-VALID TO TRUE
    SET CARD-UNCHANGED TO TRUE
    MOVE WS-CURRENT-NAME TO WS-NEW-NAME
    MOVE WS-CURRENT-EXPIRY TO WS-NEW-EXPIRY
    MOVE WS-CURRENT-STATUS TO WS-NEW-STATUS
    MOVE SPACES TO WS-MESSAGE

    DISPLAY SPACE
    DISPLAY "Press Enter to keep the current value."
    DISPLAY "New embossed name: " WITH NO ADVANCING
    ACCEPT WS-NAME-INPUT
    IF FUNCTION TRIM(WS-NAME-INPUT) NOT = SPACES
        MOVE FUNCTION TRIM(WS-NAME-INPUT) TO WS-NEW-NAME
        PERFORM VALIDATE-NAME
    END-IF

    DISPLAY "New expiry month (MM): " WITH NO ADVANCING
    ACCEPT WS-MONTH-INPUT
    IF FUNCTION TRIM(WS-MONTH-INPUT) NOT = SPACES
        IF FUNCTION TEST-NUMVAL(FUNCTION TRIM(WS-MONTH-INPUT)) = 0
            COMPUTE WS-WORK-MONTH = FUNCTION NUMVAL(FUNCTION TRIM(WS-MONTH-INPUT))
            IF WS-WORK-MONTH < 1 OR WS-WORK-MONTH > 12
                SET INPUT-INVALID TO TRUE
                MOVE "Card expiry month must be between 1 and 12." TO WS-MESSAGE
            END-IF
        ELSE
            SET INPUT-INVALID TO TRUE
            MOVE "Card expiry month must be between 1 and 12." TO WS-MESSAGE
        END-IF
    END-IF

    DISPLAY "New expiry year (YYYY): " WITH NO ADVANCING
    ACCEPT WS-YEAR-INPUT
    IF FUNCTION TRIM(WS-YEAR-INPUT) NOT = SPACES
        IF FUNCTION TEST-NUMVAL(FUNCTION TRIM(WS-YEAR-INPUT)) = 0
            COMPUTE WS-WORK-YEAR = FUNCTION NUMVAL(FUNCTION TRIM(WS-YEAR-INPUT))
            IF WS-WORK-YEAR < 1950 OR WS-WORK-YEAR > 2099
                SET INPUT-INVALID TO TRUE
                MOVE "Invalid card expiry year." TO WS-MESSAGE
            ELSE
                MOVE FUNCTION TRIM(WS-YEAR-INPUT) TO WS-NEW-EXPIRY(1:4)
            END-IF
        ELSE
            SET INPUT-INVALID TO TRUE
            MOVE "Invalid card expiry year." TO WS-MESSAGE
        END-IF
    END-IF

    DISPLAY "New active status (Y/N): " WITH NO ADVANCING
    ACCEPT WS-STATUS-INPUT
    IF FUNCTION TRIM(WS-STATUS-INPUT) NOT = SPACES
        MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-STATUS-INPUT)) TO WS-STATUS-INPUT
        IF WS-STATUS-INPUT(1:1) = "Y" OR WS-STATUS-INPUT(1:1) = "N"
            MOVE WS-STATUS-INPUT(1:1) TO WS-NEW-STATUS
        ELSE
            SET INPUT-INVALID TO TRUE
            MOVE "Card Active Status must be Y or N." TO WS-MESSAGE
        END-IF
    END-IF

    IF INPUT-VALID
        PERFORM NORMALIZE-EXPIRY
        IF WS-NEW-NAME NOT = WS-CURRENT-NAME
            OR WS-NEW-EXPIRY NOT = WS-CURRENT-EXPIRY
            OR WS-NEW-STATUS NOT = WS-CURRENT-STATUS
            SET CARD-CHANGED TO TRUE
        END-IF
    END-IF.

VALIDATE-NAME.
    IF FUNCTION TRIM(WS-NEW-NAME) = SPACES
        SET INPUT-INVALID TO TRUE
        MOVE "Card name not provided." TO WS-MESSAGE
    END-IF
    IF INPUT-VALID
        COMPUTE WS-NAME-LENGTH =
            FUNCTION LENGTH(FUNCTION TRIM(WS-NEW-NAME TRAILING))
        PERFORM VARYING WS-CHAR-IDX FROM 1 BY 1
            UNTIL WS-CHAR-IDX > WS-NAME-LENGTH OR INPUT-INVALID
            MOVE WS-NEW-NAME(WS-CHAR-IDX:1) TO WS-TEST-CHAR
            IF NOT ((WS-TEST-CHAR >= "A" AND WS-TEST-CHAR <= "Z")
                OR (WS-TEST-CHAR >= "a" AND WS-TEST-CHAR <= "z")
                OR WS-TEST-CHAR = SPACE)
                SET INPUT-INVALID TO TRUE
                MOVE "Card name can only contain alphabets and spaces."
                    TO WS-MESSAGE
            END-IF
        END-PERFORM
    END-IF.

NORMALIZE-EXPIRY.
    MOVE WS-CURRENT-EXPIRY TO WS-NEW-EXPIRY
    IF FUNCTION TRIM(WS-YEAR-INPUT) NOT = SPACES
        MOVE FUNCTION TRIM(WS-YEAR-INPUT) TO WS-NEW-EXPIRY(1:4)
    END-IF
    IF FUNCTION TRIM(WS-MONTH-INPUT) NOT = SPACES
        MOVE WS-WORK-MONTH TO WS-NEW-EXPIRY(6:2)
    END-IF.

APPLY-UPDATES.
    MOVE WS-NEW-NAME TO WS-CARD-LINE(WS-CARD-IDX)(31:50)
    MOVE WS-NEW-EXPIRY TO WS-CARD-LINE(WS-CARD-IDX)(81:10)
    MOVE WS-NEW-STATUS TO WS-CARD-LINE(WS-CARD-IDX)(91:1).

SAVE-CARDS.
    OPEN OUTPUT CARD-FILE
    IF WS-CARD-STATUS NOT = "00"
        DISPLAY "Unable to rewrite card file. Status: " WS-CARD-STATUS
        GOBACK
    END-IF
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-CARD-COUNT
        MOVE WS-CARD-LINE(WS-IDX) TO CARD-RAW-RECORD
        WRITE CARD-RAW-RECORD
    END-PERFORM
    CLOSE CARD-FILE.
