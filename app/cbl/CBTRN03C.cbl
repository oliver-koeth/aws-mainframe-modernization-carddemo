>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. CBTRN03C.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT TRANSACTION-FILE ASSIGN TO DYNAMIC WS-TRANSACTION-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-TRANSACTION-STATUS.
    SELECT XREF-FILE ASSIGN TO DYNAMIC WS-XREF-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-XREF-STATUS.
    SELECT TRANTYPE-FILE ASSIGN TO DYNAMIC WS-TRANTYPE-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-TRANTYPE-STATUS.
    SELECT TRANCATG-FILE ASSIGN TO DYNAMIC WS-TRANCATG-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-TRANCATG-STATUS.
    SELECT DATEPARM-FILE ASSIGN TO DYNAMIC WS-DATEPARM-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-DATEPARM-STATUS.
    SELECT REPORT-FILE ASSIGN TO DYNAMIC WS-REPORT-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-REPORT-STATUS.

DATA DIVISION.
FILE SECTION.
FD TRANSACTION-FILE.
01 TRANSACTION-RAW-RECORD            PIC X(350).

FD XREF-FILE.
01 XREF-RAW-RECORD                   PIC X(50).

FD TRANTYPE-FILE.
01 TRANTYPE-RAW-RECORD               PIC X(60).

FD TRANCATG-FILE.
01 TRANCATG-RAW-RECORD               PIC X(60).

FD DATEPARM-FILE.
01 DATEPARM-RAW-RECORD               PIC X(80).

FD REPORT-FILE.
01 REPORT-RAW-RECORD                 PIC X(133).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-TRANSACTION-PATH            PIC X(256) VALUE SPACES.
   05 WS-XREF-PATH                   PIC X(256) VALUE SPACES.
   05 WS-TRANTYPE-PATH               PIC X(256) VALUE SPACES.
   05 WS-TRANCATG-PATH               PIC X(256) VALUE SPACES.
   05 WS-DATEPARM-PATH               PIC X(256) VALUE SPACES.
   05 WS-REPORT-PATH                 PIC X(256) VALUE SPACES.
   05 WS-TRANSACTION-STATUS          PIC X(02) VALUE SPACES.
   05 WS-XREF-STATUS                 PIC X(02) VALUE SPACES.
   05 WS-TRANTYPE-STATUS             PIC X(02) VALUE SPACES.
   05 WS-TRANCATG-STATUS             PIC X(02) VALUE SPACES.
   05 WS-DATEPARM-STATUS             PIC X(02) VALUE SPACES.
   05 WS-REPORT-STATUS               PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-END-OF-FILE                 PIC X VALUE "N".
      88 END-OF-FILE                             VALUE "Y".
      88 MORE-RECORDS                            VALUE "N".
   05 WS-FIRST-ACCOUNT               PIC X VALUE "Y".
      88 FIRST-ACCOUNT                           VALUE "Y".
      88 NOT-FIRST-ACCOUNT                       VALUE "N".

01 WS-DATE-RANGE.
   05 WS-START-DATE                  PIC X(10) VALUE SPACES.
   05 WS-END-DATE                    PIC X(10) VALUE SPACES.

01 WS-COUNTERS.
   05 WS-XREF-COUNT                  PIC 9(04) VALUE 0.
   05 WS-TRANTYPE-COUNT              PIC 9(04) VALUE 0.
   05 WS-TRANCATG-COUNT              PIC 9(04) VALUE 0.
   05 WS-REPORT-COUNT                PIC 9(04) VALUE 0.
   05 WS-IDX                         PIC 9(04) VALUE 0.
   05 WS-JDX                         PIC 9(04) VALUE 0.
   05 WS-LINE-COUNT                  PIC 9(04) VALUE 0.
   05 WS-PAGE-SIZE                   PIC 9(02) VALUE 20.
   05 WS-COMPARE                     PIC X(17) VALUE SPACES.
   05 WS-CURRENT-CARD                PIC X(16) VALUE SPACES.

01 WS-TABLES.
   05 WS-XREF-TABLE OCCURS 500 TIMES.
      10 WS-XREF-CARD-NUM            PIC X(16).
      10 WS-XREF-ACCT-ID             PIC X(11).
   05 WS-TRANTYPE-TABLE OCCURS 50 TIMES.
      10 WS-TYPE-CODE                PIC X(02).
      10 WS-TYPE-DESC                PIC X(50).
   05 WS-TRANCATG-TABLE OCCURS 100 TIMES.
      10 WS-CAT-KEY                  PIC X(06).
      10 WS-CAT-DESC                 PIC X(50).

01 WS-REPORT-ROWS.
   05 WS-REPORT-ENTRY OCCURS 1000 TIMES.
      10 WS-REPORT-TRANS-ID          PIC X(16).
      10 WS-REPORT-CARD-NUM          PIC X(16).
      10 WS-REPORT-ACCT-ID           PIC X(11).
      10 WS-REPORT-TYPE-CD           PIC X(02).
      10 WS-REPORT-CAT-CD            PIC X(04).
      10 WS-REPORT-SOURCE            PIC X(10).
      10 WS-REPORT-AMOUNT            PIC S9(9)V99 VALUE 0.

01 WS-SWAP-AREA.
   05 WS-SWAP-TRANS-ID               PIC X(16).
   05 WS-SWAP-CARD-NUM               PIC X(16).
   05 WS-SWAP-ACCT-ID                PIC X(11).
   05 WS-SWAP-TYPE-CD                PIC X(02).
   05 WS-SWAP-CAT-CD                 PIC X(04).
   05 WS-SWAP-SOURCE                 PIC X(10).
   05 WS-SWAP-AMOUNT                 PIC S9(9)V99 VALUE 0.

01 WS-TOTALS.
   05 WS-PAGE-TOTAL                  PIC S9(9)V99 VALUE 0.
   05 WS-ACCOUNT-TOTAL               PIC S9(9)V99 VALUE 0.
   05 WS-GRAND-TOTAL                 PIC S9(9)V99 VALUE 0.

01 WS-DISPLAY.
   05 WS-AMOUNT-RAW                  PIC X(11) VALUE SPACES.
   05 WS-AMOUNT-LAST-DIGIT           PIC X(01) VALUE SPACE.
   05 WS-AMOUNT-NUMERIC              PIC 9(11) VALUE 0.
   05 WS-AMOUNT-SIGN                 PIC X(01) VALUE "+".
   05 WS-AMOUNT-VALUE                PIC S9(9)V99 VALUE 0.
   05 WS-EFFECTIVE-TRAN-DATE         PIC X(10) VALUE SPACES.
   05 WS-AMOUNT-DISPLAY              PIC -ZZZ,ZZZ,ZZZ.ZZ VALUE ZERO.
   05 WS-PAGE-TOTAL-DISPLAY          PIC +ZZZ,ZZZ,ZZZ.ZZ VALUE ZERO.
   05 WS-ACCOUNT-TOTAL-DISPLAY       PIC +ZZZ,ZZZ,ZZZ.ZZ VALUE ZERO.
   05 WS-GRAND-TOTAL-DISPLAY         PIC +ZZZ,ZZZ,ZZZ.ZZ VALUE ZERO.
   05 WS-TYPE-DESC-WORK              PIC X(50) VALUE SPACES.
   05 WS-CAT-DESC-WORK               PIC X(50) VALUE SPACES.
   05 WS-REPORT-LINE                 PIC X(133) VALUE SPACES.

PROCEDURE DIVISION.
MAIN-PARA.
    PERFORM INITIALIZE-PATHS
    PERFORM READ-DATEPARM
    PERFORM LOAD-XREF-TABLE
    PERFORM LOAD-TRANTYPE-TABLE
    PERFORM LOAD-TRANCATG-TABLE
    PERFORM LOAD-FILTERED-TRANSACTIONS
    IF WS-REPORT-COUNT = 0
        DISPLAY "No transactions found for report range "
            WS-START-DATE " to " WS-END-DATE
        GOBACK
    END-IF
    PERFORM SORT-REPORT-ROWS
    PERFORM WRITE-REPORT
    DISPLAY "Transaction report created at " FUNCTION TRIM(WS-REPORT-PATH)
    GOBACK.

INITIALIZE-PATHS.
    ACCEPT WS-TRANSACTION-PATH FROM ENVIRONMENT "CARDDEMO_TRAN_PATH"
    IF WS-TRANSACTION-PATH = SPACES
        MOVE "app/data/ASCII/dailytran.txt" TO WS-TRANSACTION-PATH
    END-IF
    ACCEPT WS-XREF-PATH FROM ENVIRONMENT "CARDDEMO_XREF_PATH"
    IF WS-XREF-PATH = SPACES
        MOVE "app/data/ASCII/cardxref.txt" TO WS-XREF-PATH
    END-IF
    ACCEPT WS-TRANTYPE-PATH FROM ENVIRONMENT "CARDDEMO_TRANTYPE_PATH"
    IF WS-TRANTYPE-PATH = SPACES
        MOVE "app/data/ASCII/trantype.txt" TO WS-TRANTYPE-PATH
    END-IF
    ACCEPT WS-TRANCATG-PATH FROM ENVIRONMENT "CARDDEMO_TRANCATG_PATH"
    IF WS-TRANCATG-PATH = SPACES
        MOVE "app/data/ASCII/trancatg.txt" TO WS-TRANCATG-PATH
    END-IF
    ACCEPT WS-DATEPARM-PATH FROM ENVIRONMENT "CARDDEMO_DATEPARM_PATH"
    IF WS-DATEPARM-PATH = SPACES
        MOVE "app/data/ASCII/dateparm.txt" TO WS-DATEPARM-PATH
    END-IF
    ACCEPT WS-REPORT-PATH FROM ENVIRONMENT "CARDDEMO_REPORT_OUTPUT_PATH"
    IF WS-REPORT-PATH = SPACES
        MOVE "app/data/ASCII/tranrept.txt" TO WS-REPORT-PATH
    END-IF.

READ-DATEPARM.
    OPEN INPUT DATEPARM-FILE
    IF WS-DATEPARM-STATUS NOT = "00"
        DISPLAY "Unable to open DATEPARM file. Status: " WS-DATEPARM-STATUS
        STOP RUN
    END-IF
    READ DATEPARM-FILE
        AT END
            DISPLAY "DATEPARM file is empty."
            STOP RUN
        NOT AT END
            MOVE DATEPARM-RAW-RECORD(1:10) TO WS-START-DATE
            MOVE DATEPARM-RAW-RECORD(12:10) TO WS-END-DATE
    END-READ
    CLOSE DATEPARM-FILE.

LOAD-XREF-TABLE.
    MOVE 0 TO WS-XREF-COUNT
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                ADD 1 TO WS-XREF-COUNT
                MOVE XREF-RAW-RECORD(1:16) TO WS-XREF-CARD-NUM(WS-XREF-COUNT)
                MOVE XREF-RAW-RECORD(26:11) TO WS-XREF-ACCT-ID(WS-XREF-COUNT)
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

LOAD-TRANTYPE-TABLE.
    SET MORE-RECORDS TO TRUE
    MOVE 0 TO WS-TRANTYPE-COUNT
    OPEN INPUT TRANTYPE-FILE
    IF WS-TRANTYPE-STATUS NOT = "00"
        DISPLAY "Unable to open transaction type file. Status: "
            WS-TRANTYPE-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ TRANTYPE-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                ADD 1 TO WS-TRANTYPE-COUNT
                MOVE TRANTYPE-RAW-RECORD(1:2) TO WS-TYPE-CODE(WS-TRANTYPE-COUNT)
                MOVE TRANTYPE-RAW-RECORD(3:50) TO WS-TYPE-DESC(WS-TRANTYPE-COUNT)
        END-READ
    END-PERFORM
    CLOSE TRANTYPE-FILE.

LOAD-TRANCATG-TABLE.
    SET MORE-RECORDS TO TRUE
    MOVE 0 TO WS-TRANCATG-COUNT
    OPEN INPUT TRANCATG-FILE
    IF WS-TRANCATG-STATUS NOT = "00"
        DISPLAY "Unable to open transaction category file. Status: "
            WS-TRANCATG-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ TRANCATG-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                ADD 1 TO WS-TRANCATG-COUNT
                MOVE TRANCATG-RAW-RECORD(1:6) TO WS-CAT-KEY(WS-TRANCATG-COUNT)
                MOVE TRANCATG-RAW-RECORD(7:50) TO WS-CAT-DESC(WS-TRANCATG-COUNT)
        END-READ
    END-PERFORM
    CLOSE TRANCATG-FILE.

LOAD-FILTERED-TRANSACTIONS.
    SET MORE-RECORDS TO TRUE
    MOVE 0 TO WS-REPORT-COUNT
    OPEN INPUT TRANSACTION-FILE
    IF WS-TRANSACTION-STATUS NOT = "00"
        DISPLAY "Unable to open transaction file. Status: "
            WS-TRANSACTION-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ TRANSACTION-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                PERFORM DERIVE-EFFECTIVE-TRAN-DATE
                IF WS-EFFECTIVE-TRAN-DATE >= WS-START-DATE
                    AND WS-EFFECTIVE-TRAN-DATE <= WS-END-DATE
                    ADD 1 TO WS-REPORT-COUNT
                    MOVE TRANSACTION-RAW-RECORD(1:16)
                        TO WS-REPORT-TRANS-ID(WS-REPORT-COUNT)
                    MOVE TRANSACTION-RAW-RECORD(263:16)
                        TO WS-REPORT-CARD-NUM(WS-REPORT-COUNT)
                    MOVE TRANSACTION-RAW-RECORD(17:2)
                        TO WS-REPORT-TYPE-CD(WS-REPORT-COUNT)
                    MOVE TRANSACTION-RAW-RECORD(19:4)
                        TO WS-REPORT-CAT-CD(WS-REPORT-COUNT)
                    MOVE TRANSACTION-RAW-RECORD(23:10)
                        TO WS-REPORT-SOURCE(WS-REPORT-COUNT)
                    MOVE TRANSACTION-RAW-RECORD(133:11) TO WS-AMOUNT-RAW
                    PERFORM DECODE-AMOUNT
                    MOVE WS-AMOUNT-VALUE TO WS-REPORT-AMOUNT(WS-REPORT-COUNT)
                    PERFORM LOOKUP-ACCOUNT-ID
                    MOVE WS-COMPARE(1:11) TO WS-REPORT-ACCT-ID(WS-REPORT-COUNT)
                END-IF
        END-READ
    END-PERFORM
    CLOSE TRANSACTION-FILE.

DERIVE-EFFECTIVE-TRAN-DATE.
    IF TRANSACTION-RAW-RECORD(305:10) NOT = SPACES
        MOVE TRANSACTION-RAW-RECORD(305:10) TO WS-EFFECTIVE-TRAN-DATE
    ELSE
        MOVE TRANSACTION-RAW-RECORD(279:10) TO WS-EFFECTIVE-TRAN-DATE
    END-IF.

LOOKUP-ACCOUNT-ID.
    MOVE SPACES TO WS-COMPARE
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-XREF-COUNT
        IF WS-XREF-CARD-NUM(WS-IDX) = WS-REPORT-CARD-NUM(WS-REPORT-COUNT)
            MOVE WS-XREF-ACCT-ID(WS-IDX) TO WS-COMPARE(1:11)
            EXIT PERFORM
        END-IF
    END-PERFORM.

SORT-REPORT-ROWS.
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX >= WS-REPORT-COUNT
        COMPUTE WS-JDX = WS-IDX + 1
        PERFORM UNTIL WS-JDX > WS-REPORT-COUNT
            IF WS-REPORT-CARD-NUM(WS-IDX) > WS-REPORT-CARD-NUM(WS-JDX)
                OR (WS-REPORT-CARD-NUM(WS-IDX) = WS-REPORT-CARD-NUM(WS-JDX)
                    AND WS-REPORT-TRANS-ID(WS-IDX) > WS-REPORT-TRANS-ID(WS-JDX))
                PERFORM SWAP-REPORT-ROWS
            END-IF
            ADD 1 TO WS-JDX
        END-PERFORM
    END-PERFORM.

SWAP-REPORT-ROWS.
    MOVE WS-REPORT-TRANS-ID(WS-IDX) TO WS-SWAP-TRANS-ID
    MOVE WS-REPORT-CARD-NUM(WS-IDX) TO WS-SWAP-CARD-NUM
    MOVE WS-REPORT-ACCT-ID(WS-IDX) TO WS-SWAP-ACCT-ID
    MOVE WS-REPORT-TYPE-CD(WS-IDX) TO WS-SWAP-TYPE-CD
    MOVE WS-REPORT-CAT-CD(WS-IDX) TO WS-SWAP-CAT-CD
    MOVE WS-REPORT-SOURCE(WS-IDX) TO WS-SWAP-SOURCE
    MOVE WS-REPORT-AMOUNT(WS-IDX) TO WS-SWAP-AMOUNT
    MOVE WS-REPORT-TRANS-ID(WS-JDX) TO WS-REPORT-TRANS-ID(WS-IDX)
    MOVE WS-REPORT-CARD-NUM(WS-JDX) TO WS-REPORT-CARD-NUM(WS-IDX)
    MOVE WS-REPORT-ACCT-ID(WS-JDX) TO WS-REPORT-ACCT-ID(WS-IDX)
    MOVE WS-REPORT-TYPE-CD(WS-JDX) TO WS-REPORT-TYPE-CD(WS-IDX)
    MOVE WS-REPORT-CAT-CD(WS-JDX) TO WS-REPORT-CAT-CD(WS-IDX)
    MOVE WS-REPORT-SOURCE(WS-JDX) TO WS-REPORT-SOURCE(WS-IDX)
    MOVE WS-REPORT-AMOUNT(WS-JDX) TO WS-REPORT-AMOUNT(WS-IDX)
    MOVE WS-SWAP-TRANS-ID TO WS-REPORT-TRANS-ID(WS-JDX)
    MOVE WS-SWAP-CARD-NUM TO WS-REPORT-CARD-NUM(WS-JDX)
    MOVE WS-SWAP-ACCT-ID TO WS-REPORT-ACCT-ID(WS-JDX)
    MOVE WS-SWAP-TYPE-CD TO WS-REPORT-TYPE-CD(WS-JDX)
    MOVE WS-SWAP-CAT-CD TO WS-REPORT-CAT-CD(WS-JDX)
    MOVE WS-SWAP-SOURCE TO WS-REPORT-SOURCE(WS-JDX)
    MOVE WS-SWAP-AMOUNT TO WS-REPORT-AMOUNT(WS-JDX).

WRITE-REPORT.
    OPEN OUTPUT REPORT-FILE
    IF WS-REPORT-STATUS NOT = "00"
        DISPLAY "Unable to open report output file. Status: " WS-REPORT-STATUS
        STOP RUN
    END-IF
    MOVE 0 TO WS-LINE-COUNT WS-PAGE-TOTAL WS-ACCOUNT-TOTAL WS-GRAND-TOTAL
    SET FIRST-ACCOUNT TO TRUE
    PERFORM WRITE-HEADERS
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-REPORT-COUNT
        IF FIRST-ACCOUNT
            MOVE WS-REPORT-CARD-NUM(WS-IDX) TO WS-CURRENT-CARD
            SET NOT-FIRST-ACCOUNT TO TRUE
        END-IF
        IF WS-REPORT-CARD-NUM(WS-IDX) NOT = WS-CURRENT-CARD
            PERFORM WRITE-ACCOUNT-TOTAL
            MOVE WS-REPORT-CARD-NUM(WS-IDX) TO WS-CURRENT-CARD
        END-IF
        IF FUNCTION MOD(WS-LINE-COUNT, WS-PAGE-SIZE) = 0
            AND WS-LINE-COUNT > 0
            PERFORM WRITE-PAGE-TOTAL
            PERFORM WRITE-HEADERS
        END-IF
        ADD WS-REPORT-AMOUNT(WS-IDX) TO WS-PAGE-TOTAL WS-ACCOUNT-TOTAL
        PERFORM WRITE-DETAIL
    END-PERFORM
    PERFORM WRITE-ACCOUNT-TOTAL
    PERFORM WRITE-PAGE-TOTAL
    PERFORM WRITE-GRAND-TOTAL
    CLOSE REPORT-FILE.

WRITE-HEADERS.
    MOVE SPACES TO WS-REPORT-LINE
    STRING
        "DALYREPT Daily Transaction Report Date Range: "
        DELIMITED BY SIZE
        WS-START-DATE DELIMITED BY SIZE
        " to " DELIMITED BY SIZE
        WS-END-DATE DELIMITED BY SIZE
        INTO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE
    MOVE SPACES TO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE
    MOVE
        "Transaction ID    Account ID    Transaction Type   Tran Category                      Source            Amount"
        TO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE
    MOVE ALL "-" TO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE.

WRITE-DETAIL.
    PERFORM LOOKUP-TYPE-DESC
    PERFORM LOOKUP-CAT-DESC
    MOVE WS-REPORT-AMOUNT(WS-IDX) TO WS-AMOUNT-DISPLAY
    MOVE SPACES TO WS-REPORT-LINE
    STRING
        WS-REPORT-TRANS-ID(WS-IDX) DELIMITED BY SIZE
        " " DELIMITED BY SIZE
        WS-REPORT-ACCT-ID(WS-IDX) DELIMITED BY SIZE
        " " DELIMITED BY SIZE
        WS-REPORT-TYPE-CD(WS-IDX) DELIMITED BY SIZE
        "-" DELIMITED BY SIZE
        FUNCTION TRIM(WS-TYPE-DESC-WORK) DELIMITED BY SIZE
        " " DELIMITED BY SIZE
        WS-REPORT-CAT-CD(WS-IDX) DELIMITED BY SIZE
        "-" DELIMITED BY SIZE
        FUNCTION TRIM(WS-CAT-DESC-WORK) DELIMITED BY SIZE
        " " DELIMITED BY SIZE
        FUNCTION TRIM(WS-REPORT-SOURCE(WS-IDX)) DELIMITED BY SIZE
        " " DELIMITED BY SIZE
        WS-AMOUNT-DISPLAY DELIMITED BY SIZE
        INTO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE
    ADD 1 TO WS-LINE-COUNT.

WRITE-PAGE-TOTAL.
    MOVE WS-PAGE-TOTAL TO WS-PAGE-TOTAL-DISPLAY
    MOVE SPACES TO WS-REPORT-LINE
    STRING
        "Page Total"
        DELIMITED BY SIZE
        " ................................................................. "
        DELIMITED BY SIZE
        WS-PAGE-TOTAL-DISPLAY DELIMITED BY SIZE
        INTO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE
    ADD WS-PAGE-TOTAL TO WS-GRAND-TOTAL
    MOVE 0 TO WS-PAGE-TOTAL
    MOVE ALL "-" TO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE.

WRITE-ACCOUNT-TOTAL.
    MOVE WS-ACCOUNT-TOTAL TO WS-ACCOUNT-TOTAL-DISPLAY
    MOVE SPACES TO WS-REPORT-LINE
    STRING
        "Account Total"
        DELIMITED BY SIZE
        " .............................................................. "
        DELIMITED BY SIZE
        WS-ACCOUNT-TOTAL-DISPLAY DELIMITED BY SIZE
        INTO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE
    MOVE 0 TO WS-ACCOUNT-TOTAL
    MOVE ALL "-" TO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE.

WRITE-GRAND-TOTAL.
    MOVE WS-GRAND-TOTAL TO WS-GRAND-TOTAL-DISPLAY
    MOVE SPACES TO WS-REPORT-LINE
    STRING
        "Grand Total"
        DELIMITED BY SIZE
        " ............................................................... "
        DELIMITED BY SIZE
        WS-GRAND-TOTAL-DISPLAY DELIMITED BY SIZE
        INTO WS-REPORT-LINE
    WRITE REPORT-RAW-RECORD FROM WS-REPORT-LINE.

LOOKUP-TYPE-DESC.
    MOVE SPACES TO WS-TYPE-DESC-WORK
    PERFORM VARYING WS-JDX FROM 1 BY 1 UNTIL WS-JDX > WS-TRANTYPE-COUNT
        IF WS-TYPE-CODE(WS-JDX) = WS-REPORT-TYPE-CD(WS-IDX)
            MOVE WS-TYPE-DESC(WS-JDX) TO WS-TYPE-DESC-WORK
            EXIT PERFORM
        END-IF
    END-PERFORM.

LOOKUP-CAT-DESC.
    MOVE SPACES TO WS-CAT-DESC-WORK
    MOVE SPACES TO WS-COMPARE
    STRING WS-REPORT-TYPE-CD(WS-IDX) WS-REPORT-CAT-CD(WS-IDX)
        DELIMITED BY SIZE INTO WS-COMPARE
    PERFORM VARYING WS-JDX FROM 1 BY 1 UNTIL WS-JDX > WS-TRANCATG-COUNT
        IF WS-CAT-KEY(WS-JDX) = WS-COMPARE(1:6)
            MOVE WS-CAT-DESC(WS-JDX) TO WS-CAT-DESC-WORK
            EXIT PERFORM
        END-IF
    END-PERFORM.

DECODE-AMOUNT.
    MOVE 0 TO WS-AMOUNT-NUMERIC
    MOVE "+" TO WS-AMOUNT-SIGN
    MOVE WS-AMOUNT-RAW(11:1) TO WS-AMOUNT-LAST-DIGIT
    EVALUATE WS-AMOUNT-LAST-DIGIT
        WHEN "{"
            MOVE "0" TO WS-AMOUNT-RAW(11:1)
        WHEN "A"
            MOVE "1" TO WS-AMOUNT-RAW(11:1)
        WHEN "B"
            MOVE "2" TO WS-AMOUNT-RAW(11:1)
        WHEN "C"
            MOVE "3" TO WS-AMOUNT-RAW(11:1)
        WHEN "D"
            MOVE "4" TO WS-AMOUNT-RAW(11:1)
        WHEN "E"
            MOVE "5" TO WS-AMOUNT-RAW(11:1)
        WHEN "F"
            MOVE "6" TO WS-AMOUNT-RAW(11:1)
        WHEN "G"
            MOVE "7" TO WS-AMOUNT-RAW(11:1)
        WHEN "H"
            MOVE "8" TO WS-AMOUNT-RAW(11:1)
        WHEN "I"
            MOVE "9" TO WS-AMOUNT-RAW(11:1)
        WHEN "}"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "0" TO WS-AMOUNT-RAW(11:1)
        WHEN "J"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "1" TO WS-AMOUNT-RAW(11:1)
        WHEN "K"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "2" TO WS-AMOUNT-RAW(11:1)
        WHEN "L"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "3" TO WS-AMOUNT-RAW(11:1)
        WHEN "M"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "4" TO WS-AMOUNT-RAW(11:1)
        WHEN "N"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "5" TO WS-AMOUNT-RAW(11:1)
        WHEN "O"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "6" TO WS-AMOUNT-RAW(11:1)
        WHEN "P"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "7" TO WS-AMOUNT-RAW(11:1)
        WHEN "Q"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "8" TO WS-AMOUNT-RAW(11:1)
        WHEN "R"
            MOVE "-" TO WS-AMOUNT-SIGN
            MOVE "9" TO WS-AMOUNT-RAW(11:1)
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    COMPUTE WS-AMOUNT-NUMERIC = FUNCTION NUMVAL(WS-AMOUNT-RAW)
    COMPUTE WS-AMOUNT-VALUE = WS-AMOUNT-NUMERIC / 100
    IF WS-AMOUNT-SIGN = "-"
        COMPUTE WS-AMOUNT-VALUE = WS-AMOUNT-VALUE * -1
    END-IF.
