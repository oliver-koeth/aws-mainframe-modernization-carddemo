>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. COCRDSLC.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT CARD-FILE ASSIGN TO DYNAMIC WS-CARD-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-CARD-STATUS.
    SELECT XREF-FILE ASSIGN TO DYNAMIC WS-XREF-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-XREF-STATUS.

DATA DIVISION.
FILE SECTION.
FD CARD-FILE.
01 CARD-RAW-RECORD                  PIC X(150).

FD XREF-FILE.
01 XREF-RAW-RECORD                  PIC X(50).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-CARD-PATH                  PIC X(256) VALUE SPACES.
   05 WS-XREF-PATH                  PIC X(256) VALUE SPACES.
   05 WS-CARD-STATUS                PIC X(02) VALUE SPACES.
   05 WS-XREF-STATUS                PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-END-OF-FILE                PIC X VALUE "N".
      88 END-OF-FILE                            VALUE "Y".
      88 MORE-RECORDS                           VALUE "N".
   05 WS-CARD-FOUND                 PIC X VALUE "N".
      88 CARD-FOUND                             VALUE "Y".
      88 CARD-NOT-FOUND                         VALUE "N".
   05 WS-XREF-FOUND                 PIC X VALUE "N".
      88 XREF-FOUND                             VALUE "Y".
      88 XREF-NOT-FOUND                         VALUE "N".

01 WS-SEARCH.
   05 WS-SEARCH-ACCOUNT-ID          PIC X(11) VALUE SPACES.
   05 WS-SEARCH-CARD-NUM            PIC X(16) VALUE SPACES.

01 WS-CURRENT.
   05 WS-CURRENT-CARD-LINE          PIC X(150) VALUE SPACES.
   05 WS-CURRENT-CARD-NUM           PIC X(16) VALUE SPACES.
   05 WS-CURRENT-ACCT-ID            PIC X(11) VALUE SPACES.
   05 WS-CURRENT-CUST-ID            PIC X(09) VALUE SPACES.
   05 WS-CURRENT-CVV                PIC X(03) VALUE SPACES.
   05 WS-CURRENT-NAME               PIC X(50) VALUE SPACES.
   05 WS-CURRENT-EXPIRY             PIC X(10) VALUE SPACES.
   05 WS-CURRENT-STATUS             PIC X(01) VALUE SPACES.

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATHS
    PERFORM PROMPT-FOR-LOOKUP
    PERFORM RESOLVE-CARD
    IF CARD-NOT-FOUND
        DISPLAY "Credit card view failed: card not found."
        GOBACK
    END-IF
    PERFORM DISPLAY-CARD
    GOBACK.

INITIALIZE-PATHS.
    ACCEPT WS-CARD-PATH FROM ENVIRONMENT "CARDDEMO_CARD_PATH"
    IF WS-CARD-PATH = SPACES
        MOVE "app/data/ASCII/carddata.txt" TO WS-CARD-PATH
    END-IF
    ACCEPT WS-XREF-PATH FROM ENVIRONMENT "CARDDEMO_XREF_PATH"
    IF WS-XREF-PATH = SPACES
        MOVE "app/data/ASCII/cardxref.txt" TO WS-XREF-PATH
    END-IF.

PROMPT-FOR-LOOKUP.
    DISPLAY SPACE
    DISPLAY "Credit Card View"
    DISPLAY "Lookup by account ID or card number."
    DISPLAY "Account ID (11 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-ACCOUNT-ID
    DISPLAY "Card Number (16 digits, optional): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-CARD-NUM.

RESOLVE-CARD.
    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
        AND FUNCTION TRIM(WS-SEARCH-CARD-NUM) = SPACES
        DISPLAY "You must enter an account ID or a card number."
        GOBACK
    END-IF

    SET XREF-NOT-FOUND TO TRUE
    IF FUNCTION TRIM(WS-SEARCH-CARD-NUM) NOT = SPACES
        PERFORM FIND-XREF-BY-CARD
        IF XREF-FOUND
            IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
                MOVE WS-CURRENT-ACCT-ID TO WS-SEARCH-ACCOUNT-ID
            ELSE
                IF WS-CURRENT-ACCT-ID NOT = WS-SEARCH-ACCOUNT-ID
                    DISPLAY "Supplied account ID does not match the card number."
                    GOBACK
                END-IF
            END-IF
        END-IF
    ELSE
        PERFORM FIND-XREF-BY-ACCOUNT
        IF XREF-FOUND
            MOVE WS-CURRENT-CARD-NUM TO WS-SEARCH-CARD-NUM
        END-IF
    END-IF

    PERFORM FIND-CARD-RECORD
    IF CARD-FOUND
        PERFORM EXTRACT-CARD-FIELDS
    END-IF.

FIND-XREF-BY-CARD.
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(1:16) = WS-SEARCH-CARD-NUM
                    MOVE XREF-RAW-RECORD(1:16) TO WS-CURRENT-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-CURRENT-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-CURRENT-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

FIND-XREF-BY-ACCOUNT.
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(26:11) = WS-SEARCH-ACCOUNT-ID
                    MOVE XREF-RAW-RECORD(1:16) TO WS-CURRENT-CARD-NUM
                    MOVE XREF-RAW-RECORD(17:9) TO WS-CURRENT-CUST-ID
                    MOVE XREF-RAW-RECORD(26:11) TO WS-CURRENT-ACCT-ID
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

FIND-CARD-RECORD.
    SET CARD-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT CARD-FILE
    IF WS-CARD-STATUS NOT = "00"
        DISPLAY "Unable to open card file. Status: " WS-CARD-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE OR CARD-FOUND
        READ CARD-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF CARD-RAW-RECORD(1:16) = WS-SEARCH-CARD-NUM
                    MOVE CARD-RAW-RECORD TO WS-CURRENT-CARD-LINE
                    SET CARD-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE CARD-FILE.

EXTRACT-CARD-FIELDS.
    IF WS-CURRENT-CARD-NUM = SPACES
        MOVE WS-CURRENT-CARD-LINE(1:16) TO WS-CURRENT-CARD-NUM
    END-IF
    IF WS-CURRENT-ACCT-ID = SPACES
        MOVE WS-CURRENT-CARD-LINE(17:11) TO WS-CURRENT-ACCT-ID
    END-IF
    MOVE WS-CURRENT-CARD-LINE(28:3) TO WS-CURRENT-CVV
    MOVE WS-CURRENT-CARD-LINE(31:50) TO WS-CURRENT-NAME
    MOVE WS-CURRENT-CARD-LINE(81:10) TO WS-CURRENT-EXPIRY
    MOVE WS-CURRENT-CARD-LINE(91:1) TO WS-CURRENT-STATUS.

DISPLAY-CARD.
    DISPLAY SPACE
    DISPLAY "Credit Card Details"
    DISPLAY "Card Number    : " WS-CURRENT-CARD-NUM
    DISPLAY "Account ID     : " WS-CURRENT-ACCT-ID
    IF WS-CURRENT-CUST-ID NOT = SPACES
        DISPLAY "Customer ID    : " WS-CURRENT-CUST-ID
    END-IF
    DISPLAY "CVV            : " WS-CURRENT-CVV
    DISPLAY "Embossed Name  : " FUNCTION TRIM(WS-CURRENT-NAME)
    DISPLAY "Expiry Date    : " WS-CURRENT-EXPIRY
    DISPLAY "Active Status  : " WS-CURRENT-STATUS.
