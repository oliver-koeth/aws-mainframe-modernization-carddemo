>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. COBIL00C.
AUTHOR. AWS.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT ACCOUNT-FILE ASSIGN TO DYNAMIC WS-ACCOUNT-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-ACCOUNT-STATUS.
    SELECT XREF-FILE ASSIGN TO DYNAMIC WS-XREF-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-XREF-STATUS.
    SELECT TRANSACTION-FILE ASSIGN TO DYNAMIC WS-TRANSACTION-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-TRANSACTION-STATUS.

DATA DIVISION.
FILE SECTION.
FD ACCOUNT-FILE.
01 ACCOUNT-RAW-RECORD                PIC X(300).

FD XREF-FILE.
01 XREF-RAW-RECORD                   PIC X(50).

FD TRANSACTION-FILE.
01 TRANSACTION-RAW-RECORD            PIC X(350).

WORKING-STORAGE SECTION.
01 WS-PATHS.
   05 WS-ACCOUNT-PATH                PIC X(256) VALUE SPACES.
   05 WS-XREF-PATH                   PIC X(256) VALUE SPACES.
   05 WS-TRANSACTION-PATH            PIC X(256) VALUE SPACES.
   05 WS-ACCOUNT-STATUS              PIC X(02) VALUE SPACES.
   05 WS-XREF-STATUS                 PIC X(02) VALUE SPACES.
   05 WS-TRANSACTION-STATUS          PIC X(02) VALUE SPACES.

01 WS-FLAGS.
   05 WS-END-OF-FILE                 PIC X VALUE "N".
      88 END-OF-FILE                             VALUE "Y".
      88 MORE-RECORDS                            VALUE "N".
   05 WS-ACCOUNT-FOUND               PIC X VALUE "N".
      88 ACCOUNT-FOUND                           VALUE "Y".
      88 ACCOUNT-NOT-FOUND                       VALUE "N".
   05 WS-XREF-FOUND                  PIC X VALUE "N".
      88 XREF-FOUND                              VALUE "Y".
      88 XREF-NOT-FOUND                          VALUE "N".

01 WS-SEARCH.
   05 WS-SEARCH-ACCOUNT-ID           PIC X(11) VALUE SPACES.

01 WS-INDICES.
   05 WS-ACCOUNT-COUNT               PIC 9(04) VALUE 0.
   05 WS-ACCOUNT-IDX                 PIC 9(04) VALUE 0.
   05 WS-IDX                         PIC 9(04) VALUE 0.
   05 WS-LAST-TRAN-ID-N              PIC 9(16) VALUE 0.

01 WS-ACCOUNT-TABLE.
   05 WS-ACCOUNT-ENTRY OCCURS 500 TIMES.
      10 WS-ACCOUNT-LINE             PIC X(300).

01 WS-CURRENT.
   05 WS-CURRENT-ACCOUNT-ID          PIC X(11) VALUE SPACES.
   05 WS-CURRENT-CARD-NUM            PIC X(16) VALUE SPACES.
   05 WS-CURRENT-BALANCE-RAW         PIC X(12) VALUE SPACES.
   05 WS-CURRENT-BALANCE-NUMERIC     PIC 9(12) VALUE 0.
   05 WS-CURRENT-BALANCE-VALUE       PIC S9(10)V99 VALUE 0.
   05 WS-CURRENT-BALANCE-DISPLAY     PIC -ZZZZZZZZZ9.99 VALUE ZERO.
   05 WS-BALANCE-SIGN                PIC X(01) VALUE "+".
   05 WS-BALANCE-LAST-DIGIT          PIC X(01) VALUE SPACE.

01 WS-WORK.
   05 WS-CONFIRM                     PIC X(10) VALUE SPACES.
   05 WS-NEW-TRAN-ID                 PIC X(16) VALUE SPACES.
   05 WS-NEW-TRAN-RECORD             PIC X(350) VALUE SPACES.
   05 WS-ZERO-BALANCE-RAW            PIC X(12) VALUE "00000000000{".
   05 WS-TRAN-AMOUNT-ABS             PIC 9(11) VALUE 0.
   05 WS-TRAN-AMOUNT-ABS-TEXT        PIC 9(11) VALUE 0.
   05 WS-TRAN-AMOUNT-RAW REDEFINES WS-TRAN-AMOUNT-ABS-TEXT PIC X(11).
   05 WS-TIMESTAMP-DATE              PIC X(10) VALUE SPACES.
   05 WS-TIMESTAMP-TIME              PIC X(08) VALUE SPACES.
   05 WS-TIMESTAMP                   PIC X(26) VALUE SPACES.

LINKAGE SECTION.
01 CARDDEMO-COMMAREA.
   05 CDEMO-GENERAL-INFO.
      10 CDEMO-FROM-TRANID             PIC X(04).
      10 CDEMO-FROM-PROGRAM            PIC X(08).
      10 CDEMO-TO-TRANID               PIC X(04).
      10 CDEMO-TO-PROGRAM              PIC X(08).
      10 CDEMO-USER-ID                 PIC X(08).
      10 CDEMO-USER-TYPE               PIC X(01).
         88 CDEMO-USRTYP-ADMIN         VALUE "A".
         88 CDEMO-USRTYP-USER          VALUE "U".
      10 CDEMO-PGM-CONTEXT             PIC 9(01).
   05 FILLER                           PIC X(120).

PROCEDURE DIVISION USING CARDDEMO-COMMAREA.
MAIN-PARA.
    PERFORM INITIALIZE-PATHS
    PERFORM LOAD-ACCOUNT-TABLE
    PERFORM PROMPT-FOR-ACCOUNT
    PERFORM RESOLVE-ACCOUNT
    IF ACCOUNT-NOT-FOUND
        DISPLAY "Bill payment failed: account not found."
        GOBACK
    END-IF
    PERFORM DISPLAY-CURRENT-BALANCE
    IF WS-CURRENT-BALANCE-VALUE <= 0
        DISPLAY "You have nothing to pay."
        GOBACK
    END-IF
    DISPLAY "Confirm bill payment in full (Y/N): " WITH NO ADVANCING
    ACCEPT WS-CONFIRM
    IF FUNCTION UPPER-CASE(FUNCTION TRIM(WS-CONFIRM))(1:1) NOT = "Y"
        DISPLAY "Bill payment cancelled."
        GOBACK
    END-IF
    PERFORM ASSIGN-NEXT-TRANSACTION-ID
    PERFORM BUILD-BILL-PAYMENT-TRANSACTION
    PERFORM APPEND-TRANSACTION
    PERFORM APPLY-ACCOUNT-PAYMENT
    PERFORM SAVE-ACCOUNT-TABLE
    DISPLAY "Bill payment complete. Tran ID: " WS-NEW-TRAN-ID
    GOBACK.

INITIALIZE-PATHS.
    ACCEPT WS-ACCOUNT-PATH FROM ENVIRONMENT "CARDDEMO_ACCT_PATH"
    IF WS-ACCOUNT-PATH = SPACES
        MOVE "app/data/ASCII/acctdata.txt" TO WS-ACCOUNT-PATH
    END-IF
    ACCEPT WS-XREF-PATH FROM ENVIRONMENT "CARDDEMO_XREF_PATH"
    IF WS-XREF-PATH = SPACES
        MOVE "app/data/ASCII/cardxref.txt" TO WS-XREF-PATH
    END-IF
    ACCEPT WS-TRANSACTION-PATH FROM ENVIRONMENT "CARDDEMO_TRAN_PATH"
    IF WS-TRANSACTION-PATH = SPACES
        MOVE "app/data/ASCII/dailytran.txt" TO WS-TRANSACTION-PATH
    END-IF.

LOAD-ACCOUNT-TABLE.
    MOVE 0 TO WS-ACCOUNT-COUNT
    SET MORE-RECORDS TO TRUE
    OPEN INPUT ACCOUNT-FILE
    IF WS-ACCOUNT-STATUS NOT = "00"
        DISPLAY "Unable to open account file. Status: " WS-ACCOUNT-STATUS
        STOP RUN
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ ACCOUNT-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                ADD 1 TO WS-ACCOUNT-COUNT
                MOVE ACCOUNT-RAW-RECORD TO WS-ACCOUNT-LINE(WS-ACCOUNT-COUNT)
        END-READ
    END-PERFORM
    CLOSE ACCOUNT-FILE.

PROMPT-FOR-ACCOUNT.
    DISPLAY SPACE
    DISPLAY "Bill Payment"
    DISPLAY "Account ID (11 digits): " WITH NO ADVANCING
    ACCEPT WS-SEARCH-ACCOUNT-ID.

RESOLVE-ACCOUNT.
    SET ACCOUNT-NOT-FOUND TO TRUE
    IF FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID) = SPACES
        DISPLAY "Account ID cannot be empty."
        GOBACK
    END-IF
    IF FUNCTION TEST-NUMVAL(FUNCTION TRIM(WS-SEARCH-ACCOUNT-ID)) NOT = 0
        DISPLAY "Account ID must be numeric."
        GOBACK
    END-IF
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-ACCOUNT-COUNT OR ACCOUNT-FOUND
        IF WS-ACCOUNT-LINE(WS-IDX)(1:11) = WS-SEARCH-ACCOUNT-ID
            MOVE WS-IDX TO WS-ACCOUNT-IDX
            MOVE WS-ACCOUNT-LINE(WS-IDX)(1:11) TO WS-CURRENT-ACCOUNT-ID
            MOVE WS-ACCOUNT-LINE(WS-IDX)(13:12) TO WS-CURRENT-BALANCE-RAW
            SET ACCOUNT-FOUND TO TRUE
        END-IF
    END-PERFORM
    IF ACCOUNT-FOUND
        PERFORM FIND-XREF-BY-ACCOUNT
        PERFORM DECODE-BALANCE
    END-IF.

FIND-XREF-BY-ACCOUNT.
    SET XREF-NOT-FOUND TO TRUE
    SET MORE-RECORDS TO TRUE
    OPEN INPUT XREF-FILE
    IF WS-XREF-STATUS NOT = "00"
        DISPLAY "Unable to open xref file. Status: " WS-XREF-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE OR XREF-FOUND
        READ XREF-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF XREF-RAW-RECORD(26:11) = WS-CURRENT-ACCOUNT-ID
                    MOVE XREF-RAW-RECORD(1:16) TO WS-CURRENT-CARD-NUM
                    SET XREF-FOUND TO TRUE
                END-IF
        END-READ
    END-PERFORM
    CLOSE XREF-FILE.

DECODE-BALANCE.
    MOVE 0 TO WS-CURRENT-BALANCE-NUMERIC
    MOVE "+" TO WS-BALANCE-SIGN
    MOVE WS-CURRENT-BALANCE-RAW(12:1) TO WS-BALANCE-LAST-DIGIT
    EVALUATE WS-BALANCE-LAST-DIGIT
        WHEN "{"
            MOVE "0" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "A"
            MOVE "1" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "B"
            MOVE "2" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "C"
            MOVE "3" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "D"
            MOVE "4" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "E"
            MOVE "5" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "F"
            MOVE "6" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "G"
            MOVE "7" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "H"
            MOVE "8" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "I"
            MOVE "9" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "}"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "0" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "J"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "1" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "K"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "2" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "L"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "3" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "M"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "4" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "N"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "5" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "O"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "6" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "P"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "7" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "Q"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "8" TO WS-CURRENT-BALANCE-RAW(12:1)
        WHEN "R"
            MOVE "-" TO WS-BALANCE-SIGN
            MOVE "9" TO WS-CURRENT-BALANCE-RAW(12:1)
    END-EVALUATE
    COMPUTE WS-CURRENT-BALANCE-NUMERIC =
        FUNCTION NUMVAL(WS-CURRENT-BALANCE-RAW)
    COMPUTE WS-CURRENT-BALANCE-VALUE =
        WS-CURRENT-BALANCE-NUMERIC / 100
    IF WS-BALANCE-SIGN = "-"
        COMPUTE WS-CURRENT-BALANCE-VALUE = WS-CURRENT-BALANCE-VALUE * -1
    END-IF
    MOVE WS-CURRENT-BALANCE-VALUE TO WS-CURRENT-BALANCE-DISPLAY.

DISPLAY-CURRENT-BALANCE.
    DISPLAY "Account ID      : " WS-CURRENT-ACCOUNT-ID
    DISPLAY "Card Number     : " WS-CURRENT-CARD-NUM
    DISPLAY "Current Balance : " WS-CURRENT-BALANCE-DISPLAY.

ASSIGN-NEXT-TRANSACTION-ID.
    MOVE 0 TO WS-LAST-TRAN-ID-N
    SET MORE-RECORDS TO TRUE
    OPEN INPUT TRANSACTION-FILE
    IF WS-TRANSACTION-STATUS NOT = "00"
        DISPLAY "Unable to open transaction file. Status: " WS-TRANSACTION-STATUS
        GOBACK
    END-IF
    PERFORM UNTIL END-OF-FILE
        READ TRANSACTION-FILE
            AT END
                SET END-OF-FILE TO TRUE
            NOT AT END
                IF TRANSACTION-RAW-RECORD(1:16) IS NUMERIC
                    COMPUTE WS-LAST-TRAN-ID-N =
                        FUNCTION NUMVAL(TRANSACTION-RAW-RECORD(1:16))
                END-IF
        END-READ
    END-PERFORM
    CLOSE TRANSACTION-FILE
    ADD 1 TO WS-LAST-TRAN-ID-N
    MOVE WS-LAST-TRAN-ID-N TO WS-NEW-TRAN-ID.

BUILD-BILL-PAYMENT-TRANSACTION.
    MOVE ALL " " TO WS-NEW-TRAN-RECORD
    STRING
        FUNCTION CURRENT-DATE(1:4) "-" FUNCTION CURRENT-DATE(5:2) "-"
        FUNCTION CURRENT-DATE(7:2)
        DELIMITED BY SIZE INTO WS-TIMESTAMP-DATE
    STRING
        FUNCTION CURRENT-DATE(9:2) ":" FUNCTION CURRENT-DATE(11:2) ":"
        FUNCTION CURRENT-DATE(13:2)
        DELIMITED BY SIZE INTO WS-TIMESTAMP-TIME
    STRING WS-TIMESTAMP-DATE " " WS-TIMESTAMP-TIME ".000000"
        DELIMITED BY SIZE INTO WS-TIMESTAMP
    MOVE WS-NEW-TRAN-ID TO WS-NEW-TRAN-RECORD(1:16)
    MOVE "02" TO WS-NEW-TRAN-RECORD(17:2)
    MOVE "0002" TO WS-NEW-TRAN-RECORD(19:4)
    MOVE "POS TERM" TO WS-NEW-TRAN-RECORD(23:10)
    MOVE "BILL PAYMENT - ONLINE" TO WS-NEW-TRAN-RECORD(33:100)
    PERFORM ENCODE-TRANSACTION-AMOUNT
    MOVE WS-TRAN-AMOUNT-RAW TO WS-NEW-TRAN-RECORD(133:11)
    MOVE "999999999" TO WS-NEW-TRAN-RECORD(144:9)
    MOVE "BILL PAYMENT" TO WS-NEW-TRAN-RECORD(153:50)
    MOVE "N/A" TO WS-NEW-TRAN-RECORD(203:50)
    MOVE "N/A" TO WS-NEW-TRAN-RECORD(253:10)
    MOVE WS-CURRENT-CARD-NUM TO WS-NEW-TRAN-RECORD(263:16)
    MOVE WS-TIMESTAMP TO WS-NEW-TRAN-RECORD(279:26)
    MOVE WS-TIMESTAMP TO WS-NEW-TRAN-RECORD(305:26).

ENCODE-TRANSACTION-AMOUNT.
    COMPUTE WS-TRAN-AMOUNT-ABS = FUNCTION ABS(WS-CURRENT-BALANCE-VALUE * 100)
    MOVE WS-TRAN-AMOUNT-ABS TO WS-TRAN-AMOUNT-ABS-TEXT
    MOVE WS-TRAN-AMOUNT-RAW(11:1) TO WS-BALANCE-LAST-DIGIT
    EVALUATE WS-BALANCE-LAST-DIGIT
        WHEN "0" MOVE "{" TO WS-TRAN-AMOUNT-RAW(11:1)
        WHEN "1" MOVE "A" TO WS-TRAN-AMOUNT-RAW(11:1)
        WHEN "2" MOVE "B" TO WS-TRAN-AMOUNT-RAW(11:1)
        WHEN "3" MOVE "C" TO WS-TRAN-AMOUNT-RAW(11:1)
        WHEN "4" MOVE "D" TO WS-TRAN-AMOUNT-RAW(11:1)
        WHEN "5" MOVE "E" TO WS-TRAN-AMOUNT-RAW(11:1)
        WHEN "6" MOVE "F" TO WS-TRAN-AMOUNT-RAW(11:1)
        WHEN "7" MOVE "G" TO WS-TRAN-AMOUNT-RAW(11:1)
        WHEN "8" MOVE "H" TO WS-TRAN-AMOUNT-RAW(11:1)
        WHEN "9" MOVE "I" TO WS-TRAN-AMOUNT-RAW(11:1)
    END-EVALUATE.

APPEND-TRANSACTION.
    OPEN EXTEND TRANSACTION-FILE
    IF WS-TRANSACTION-STATUS NOT = "00"
        DISPLAY "Unable to append transaction file. Status: " WS-TRANSACTION-STATUS
        GOBACK
    END-IF
    MOVE WS-NEW-TRAN-RECORD TO TRANSACTION-RAW-RECORD
    WRITE TRANSACTION-RAW-RECORD
    CLOSE TRANSACTION-FILE.

APPLY-ACCOUNT-PAYMENT.
    MOVE WS-ZERO-BALANCE-RAW TO WS-ACCOUNT-LINE(WS-ACCOUNT-IDX)(13:12).

SAVE-ACCOUNT-TABLE.
    OPEN OUTPUT ACCOUNT-FILE
    IF WS-ACCOUNT-STATUS NOT = "00"
        DISPLAY "Unable to rewrite account file. Status: " WS-ACCOUNT-STATUS
        GOBACK
    END-IF
    PERFORM VARYING WS-IDX FROM 1 BY 1 UNTIL WS-IDX > WS-ACCOUNT-COUNT
        MOVE WS-ACCOUNT-LINE(WS-IDX) TO ACCOUNT-RAW-RECORD
        WRITE ACCOUNT-RAW-RECORD
    END-PERFORM
    CLOSE ACCOUNT-FILE.
